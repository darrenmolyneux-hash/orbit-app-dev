      "body": "WITH new_prefix AS (\n    SELECT LPAD(FLOOR(RANDOM() * 999 + 1)::text, 3, '0') AS prefix\n)\nSELECT prefix\nFROM new_prefix np\nWHERE NOT EXISTS (\n    SELECT 1\n    FROM collections c\n    WHERE c.collection_prefix = np.prefix\n);\n",
