    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Pre-Inventory Assessment</title>\n<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 13px; color: #1a1a1a; background: #ffffff; padding: 0; }\n  .widget { padding: 16px; }\n  .widget-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; padding-bottom: 12px; border-bottom: 1px solid #f1f5f9; }\n  .widget-title { font-size: 14px; font-weight: 600; color: #1A5C3A; display: flex; align-items: center; gap: 7px; }\n  .asset-badge { background: #f1f5f9; border: 1px solid #e2e8f0; border-radius: 6px; padding: 4px 10px; font-size: 11px; color: #475569; }\n  .instructions { background: #EAF3DE; border: 1px solid #97C459; border-radius: 7px; padding: 9px 12px; font-size: 11px; color: #27500A; margin-bottom: 14px; line-height: 1.5; }\n  .instructions strong { font-weight: 600; }\n  .parts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; margin-bottom: 14px; }\n  .part-card { border: 1.5px solid #e2e8f0; border-radius: 8px; padding: 9px 11px; cursor: pointer; transition: all 0.15s; background: #fff; }\n  .part-card:hover { border-color: #94a3b8; background: #f8fafc; }\n  .part-card.is-scrap { border-color: #fca5a5; background: #fff5f5; }\n  .part-card.is-battery { border-color: #fbbf24; background: #fffbeb; }\n  .part-card.is-battery.is-scrap { border-color: #fca5a5; background: #fff5f5; }\n  .part-card-top { display: flex; align-items: flex-start; gap: 8px; }\n  .scrap-checkbox { width: 16px; height: 16px; border: 2px solid #cbd5e1; border-radius: 4px; flex-shrink: 0; margin-top: 1px; display: flex; align-items: center; justify-content: center; transition: all 0.15s; background: #fff; }\n  .part-card.is-scrap .scrap-checkbox { background: #ef4444; border-color: #ef4444; }\n  .scrap-checkbox svg { width: 10px; height: 10px; stroke: #fff; fill: none; stroke-width: 3; stroke-linecap: round; stroke-linejoin: round; opacity: 0; }\n  .part-card.is-scrap .scrap-checkbox svg { opacity: 1; }\n  .part-info { flex: 1; min-width: 0; }\n  .part-name { font-size: 12px; font-weight: 500; color: #1e293b; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\n  .part-card.is-scrap .part-name { color: #ef4444; text-decoration: line-through; }\n  .battery-tag { font-size: 9px; background: #fef3c7; color: #92400e; border-radius: 99px; padding: 1px 6px; font-weight: 500; display: inline-block; margin-top: 2px; }\n  .scrap-tag { font-size: 9px; background: #fee2e2; color: #b91c1c; border-radius: 99px; padding: 1px 6px; font-weight: 500; display: inline-block; margin-top: 2px; }\n  .part-detail-row { display: grid; grid-template-columns: 1fr 1fr; gap: 5px; margin-top: 7px; padding-top: 7px; border-top: 1px solid #f1f5f9; }\n  .part-card.is-scrap .part-detail-row { border-top-color: #fecaca; }\n  .detail-group { display: flex; flex-direction: column; gap: 2px; }\n  .detail-label { font-size: 9px; color: #94a3b8; font-weight: 500; text-transform: uppercase; letter-spacing: 0.04em; }\n  .detail-input { height: 26px; border: 1px solid #e2e8f0; border-radius: 5px; padding: 0 7px; font-size: 11px; color: #1e293b; background: #fff; width: 100%; outline: none; }\n  .detail-input:focus { border-color: #1A5C3A; }\n  .detail-select { height: 26px; border: 1px solid #e2e8f0; border-radius: 5px; padding: 0 5px; font-size: 11px; color: #1e293b; background: #fff; width: 100%; outline: none; }\n  .detail-select:focus { border-color: #1A5C3A; }\n  .battery-warn { background: #fffbeb; border: 1px solid #fbbf24; border-radius: 5px; padding: 5px 8px; font-size: 10px; color: #92400e; margin-top: 6px; grid-column: 1 / -1; }\n  .summary-bar { display: flex; align-items: center; gap: 10px; padding: 8px 12px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 7px; margin-bottom: 12px; flex-wrap: wrap; }\n  .summary-stat { display: flex; align-items: center; gap: 5px; font-size: 11px; }\n  .stat-dot { width: 8px; height: 8px; border-radius: 50%; }\n  .dot-green { background: #22c55e; }\n  .dot-red { background: #ef4444; }\n  .dot-amber { background: #f59e0b; }\n  .submit-row { display: flex; align-items: center; justify-content: space-between; gap: 10px; padding-top: 12px; border-top: 1px solid #f1f5f9; }\n  .submit-hint { font-size: 11px; color: #94a3b8; }\n  .btn-submit { height: 36px; padding: 0 20px; background: #1A5C3A; color: #fff; border: none; border-radius: 7px; font-size: 13px; font-weight: 500; cursor: pointer; display: flex; align-items: center; gap: 6px; transition: opacity 0.15s; }\n  .btn-submit:hover { opacity: 0.9; }\n  .btn-submit:disabled { opacity: 0.4; cursor: not-allowed; }\n  .success-flash { display: none; background: #E1F5EE; border: 1px solid #5DCAA5; border-radius: 7px; padding: 10px 14px; font-size: 12px; color: #085041; font-weight: 500; text-align: center; margin-bottom: 12px; }\n  .session-log { margin-top: 12px; padding-top: 12px; border-top: 1px solid #f1f5f9; }\n  .session-log-title { font-size: 10px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 7px; }\n  .log-item { display: flex; align-items: center; gap: 8px; padding: 5px 0; border-bottom: 1px solid #f8fafc; font-size: 11px; }\n  .log-badge { padding: 1px 7px; border-radius: 99px; font-size: 10px; font-weight: 500; }\n  .log-badge.salvage { background: #E1F5EE; color: #085041; }\n  .log-badge.scrap { background: #fee2e2; color: #b91c1c; }\n  @media (max-width: 500px) { .parts-grid { grid-template-columns: 1fr; } }\n</style>\n</head>\n<body>\n<div class=\"widget\">\n  <div class=\"widget-header\">\n    <div class=\"widget-title\">\n      <svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#1A5C3A\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n        <path d=\"M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2\"/>\n        <rect x=\"9\" y=\"3\" width=\"6\" height=\"4\" rx=\"2\"/>\n        <path d=\"m9 12 2 2 4-4\"/>\n      </svg>\n      Part assessment\n    </div>\n    <div class=\"asset-badge\" id=\"assetBadge\">Loading...</div>\n  </div>\n\n  <div class=\"instructions\">\n    <strong>Tick any parts that are damaged or cannot be salvaged.</strong> All unticked parts will be logged as salvageable. Ticked parts are logged as scrap.\n  </div>\n\n  <div class=\"success-flash\" id=\"successFlash\"></div>\n\n  <div class=\"summary-bar\" id=\"summaryBar\" style=\"display:none;\">\n    <div class=\"summary-stat\"><div class=\"stat-dot dot-green\"></div><span id=\"statSalvage\">0 salvageable</span></div>\n    <div class=\"summary-stat\"><div class=\"stat-dot dot-red\"></div><span id=\"statScrap\">0 scrap</span></div>\n    <div class=\"summary-stat\"><div class=\"stat-dot dot-amber\"></div><span id=\"statBattery\">0 batteries</span></div>\n  </div>\n\n  <div id=\"partsGrid\" class=\"parts-grid\">\n    <div style=\"text-align:center;padding:20px;color:#94a3b8;font-size:12px;\">Loading parts...</div>\n  </div>\n\n  <div class=\"submit-row\">\n    <div class=\"submit-hint\" id=\"submitHint\">Select parts above then submit</div>\n    <button class=\"btn-submit\" id=\"btnSubmit\" onclick=\"submitAssessment()\" disabled>\n      <svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"white\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n      Log all parts\n    </button>\n  </div>\n\n  <div class=\"session-log\" id=\"sessionLog\" style=\"display:none;\">\n    <div class=\"session-log-title\">Logged this session</div>\n    <div id=\"sessionLogItems\"></div>\n  </div>\n</div>\n\n<script>\n  var partTypes = [];\n  var partStates = {};\n  var assetData = {};\n  var sessionLog = [];\n  var dataLoaded = false;\n  var attempts = 0;\n  var maxAttempts = 60;\n\n  function loadData(pts, ast) {\n    dataLoaded = true;\n    partTypes = pts;\n    assetData = ast || {};\n    renderAssetBadge();\n    renderParts();\n  }\n\n  function checkModel() {\n    if (dataLoaded) return;\n    attempts++;\n    var model = appsmith.model || {};\n    var pts = model.partTypes || [];\n    var ast = model.asset || {};\n    if (pts.length > 0) {\n      loadData(pts, ast);\n      return;\n    }\n    if (attempts < maxAttempts) {\n      setTimeout(checkModel, 500);\n    } else {\n      document.getElementById('partsGrid').innerHTML =\n        '<div style=\"text-align:center;padding:20px;color:#ef4444;font-size:12px;\">Could not load part types. Please refresh the page.</div>';\n    }\n  }\n\n  appsmith.onReady(function() {\n    checkModel();\n  });\n\n  appsmith.onModelChange(function(newModel) {\n    var pts = newModel.partTypes || [];\n    var ast = newModel.asset || {};\n    if (pts.length > 0) {\n      dataLoaded = false;\n      loadData(pts, ast);\n    }\n  });\n\n  function renderAssetBadge() {\n    var badge = document.getElementById('assetBadge');\n    if (assetData && (assetData.make_name || assetData.asset_ref)) {\n      badge.textContent = (assetData.asset_ref || '') + ' — ' + (assetData.make_name || '') + ' ' + (assetData.model_name || '');\n    } else {\n      badge.textContent = 'Asset loading...';\n    }\n  }\n\n  function renderParts() {\n    var grid = document.getElementById('partsGrid');\n    if (!partTypes || partTypes.length === 0) {\n      grid.innerHTML = '<div style=\"text-align:center;padding:20px;color:#94a3b8;\">No parts found for this device type.</div>';\n      return;\n    }\n    partTypes.forEach(function(pt) {\n      if (!partStates[pt.part_type_id]) {\n        partStates[pt.part_type_id] = {\n          part_type_id: pt.part_type_id, name: pt.name, is_battery: pt.is_battery,\n          is_scrap: false, make: '', model: '', condition: 'B', notes: ''\n        };\n      }\n    });\n    grid.innerHTML = partTypes.map(function(pt) {\n      var state = partStates[pt.part_type_id];\n      var isScrap = state.is_scrap;\n      var isBattery = pt.is_battery;\n      return '<div class=\"part-card' + (isScrap ? ' is-scrap' : '') + (isBattery && !isScrap ? ' is-battery' : '') + '\" id=\"card_' + pt.part_type_id + '\" onclick=\"toggleScrap(' + pt.part_type_id + ', event)\">' +\n        '<div class=\"part-card-top\">' +\n          '<div class=\"scrap-checkbox\"><svg viewBox=\"0 0 12 12\"><polyline points=\"2 6 5 9 10 3\"/></svg></div>' +\n          '<div class=\"part-info\">' +\n            '<div class=\"part-name\">' + pt.name + '</div>' +\n            (isBattery ? '<span class=\"battery-tag\">Battery — R2V3 checklist at removal</span>' : '') +\n            (isScrap ? '<span class=\"scrap-tag\">Marked as scrap</span>' : '') +\n          '</div>' +\n        '</div>' +\n        '<div class=\"part-detail-row\" onclick=\"event.stopPropagation()\">' +\n          '<div class=\"detail-group\"><div class=\"detail-label\">Make</div>' +\n            '<input class=\"detail-input\" type=\"text\" placeholder=\"e.g. Samsung\" value=\"' + state.make + '\" onchange=\"updateField(' + pt.part_type_id + ',\\'make\\',this.value)\" onclick=\"event.stopPropagation()\"></div>' +\n          '<div class=\"detail-group\"><div class=\"detail-label\">Model / spec</div>' +\n            '<input class=\"detail-input\" type=\"text\" placeholder=\"e.g. 512GB NVMe\" value=\"' + state.model + '\" onchange=\"updateField(' + pt.part_type_id + ',\\'model\\',this.value)\" onclick=\"event.stopPropagation()\"></div>' +\n          '<div class=\"detail-group\"><div class=\"detail-label\">Condition</div>' +\n            '<select class=\"detail-select\" onchange=\"updateField(' + pt.part_type_id + ',\\'condition\\',this.value)\" onclick=\"event.stopPropagation()\">' +\n              '<option value=\"A\"' + (state.condition === 'A' ? ' selected' : '') + '>A — Excellent</option>' +\n              '<option value=\"B\"' + (state.condition === 'B' ? ' selected' : '') + '>B — Good</option>' +\n              '<option value=\"C\"' + (state.condition === 'C' ? ' selected' : '') + '>C — Fair</option>' +\n              '<option value=\"F\"' + (state.condition === 'F' ? ' selected' : '') + '>F — Faulty</option>' +\n              '<option value=\"U\"' + (state.condition === 'U' ? ' selected' : '') + '>U — Unknown</option>' +\n            '</select></div>' +\n          '<div class=\"detail-group\"><div class=\"detail-label\">Notes</div>' +\n            '<input class=\"detail-input\" type=\"text\" placeholder=\"Optional\" value=\"' + state.notes + '\" onchange=\"updateField(' + pt.part_type_id + ',\\'notes\\',this.value)\" onclick=\"event.stopPropagation()\"></div>' +\n          (isBattery ? '<div class=\"battery-warn\">R2V3 battery inspection checklist required at removal.</div>' : '') +\n        '</div></div>';\n    }).join('');\n    updateSummary();\n    updateSubmitButton();\n    document.getElementById('summaryBar').style.display = 'flex';\n  }\n\n  function toggleScrap(partTypeId, event) {\n    if (event.target.tagName === 'INPUT' || event.target.tagName === 'SELECT') return;\n    partStates[partTypeId].is_scrap = !partStates[partTypeId].is_scrap;\n    renderParts();\n  }\n\n  function updateField(partTypeId, field, value) {\n    partStates[partTypeId][field] = value;\n    updateSummary();\n    updateSubmitButton();\n  }\n\n  function updateSummary() {\n    var all = Object.values(partStates);\n    document.getElementById('statSalvage').textContent = all.filter(function(p) { return !p.is_scrap; }).length + ' salvageable';\n    document.getElementById('statScrap').textContent = all.filter(function(p) { return p.is_scrap; }).length + ' scrap';\n    document.getElementById('statBattery').textContent = all.filter(function(p) { return p.is_battery; }).length + ' batteries';\n  }\n\n  function updateSubmitButton() {\n    var btn = document.getElementById('btnSubmit');\n    var hint = document.getElementById('submitHint');\n    var count = Object.values(partStates).length;\n    if (count > 0) {\n      btn.disabled = false;\n      var sc = Object.values(partStates).filter(function(p) { return p.is_scrap; }).length;\n      hint.textContent = sc > 0 ? sc + ' part' + (sc > 1 ? 's' : '') + ' marked as scrap' : 'All parts marked as salvageable';\n    } else {\n      btn.disabled = true;\n      hint.textContent = 'No parts to log';\n    }\n  }\n\n  function submitAssessment() {\n    var parts = Object.values(partStates);\n    if (parts.length === 0) return;\n    var payload = parts.map(function(p) {\n      return {\n        part_type_id: p.part_type_id, part_type_name: p.name, is_battery: p.is_battery,\n        is_scrap: p.is_scrap, is_salvageable: !p.is_scrap, make: p.make || '',\n        model: p.model || '', condition: p.is_scrap ? 'F' : p.condition,\n        notes: p.notes || '', status: p.is_scrap ? 'scrapped' : 'in_asset'\n      };\n    });\n    payload.forEach(function(p) {\n      sessionLog.push({ name: p.part_type_name, salvageable: p.is_salvageable, condition: p.condition });\n    });\n    renderSessionLog();\n    appsmith.updateModel({ assessedParts: payload });\n    appsmith.triggerEvent('onPartAssessed');\n    var sc = payload.filter(function(p) { return p.is_scrap; }).length;\n    var sv = payload.filter(function(p) { return p.is_salvageable; }).length;\n    var flash = document.getElementById('successFlash');\n    flash.textContent = String.fromCharCode(10003) + ' ' + payload.length + ' parts logged — ' + sv + ' salvageable, ' + sc + ' scrap';\n    flash.style.display = 'block';\n    setTimeout(function() { flash.style.display = 'none'; }, 4000);\n    partStates = {};\n    dataLoaded = false;\n    attempts = 0;\n    checkModel();\n  }\n\n  function renderSessionLog() {\n    var log = document.getElementById('sessionLog');\n    var items = document.getElementById('sessionLogItems');\n    log.style.display = 'block';\n    items.innerHTML = sessionLog.slice(-10).reverse().map(function(item) {\n      return '<div class=\"log-item\"><span class=\"log-badge ' + (item.salvageable ? 'salvage' : 'scrap') + '\">' +\n        (item.salvageable ? 'Salvageable' : 'Scrap') + '</span><span>' + item.name + '</span>' +\n        '<span style=\"color:#94a3b8;margin-left:auto;\">Grade ' + item.condition + '</span></div>';\n    }).join('');\n  }\n</script>\n</body>\n</html>",
    "js": ""
  },
  "version": 1,
  "widgetId": "6gfqm5q5l2",
  "widgetName": "CustomPreInventory"
}