    "css": "",
    "html": "<!-- New custom widget: Custom_PreInventoryHeader. Replaces the two plain text fields at the top of the page. -->\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Figtree:wght@400;600;700&display=swap');\n  * { box-sizing: border-box; font-family: 'Figtree', sans-serif; margin: 0; padding: 0; }\n\n  .card {\n    background: #fff; border-radius: 10px; border: 0.5px solid rgba(0,0,0,0.1);\n    padding: 24px 28px;\n  }\n  .title { font-size: 28px; font-weight: 700; color: #05042E; line-height: 1.25; }\n  .subtitle { font-size: 15px; font-weight: 600; color: #469BC0; margin-top: 8px; }\n</style>\n\n<div class=\"card\" id=\"root\"></div>\n\n<script>\n  function escHtml(str) {\n    if (str === null || str === undefined) return '';\n    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');\n  }\n\n  function render(model) {\n    const m = model || {};\n    const assetRef = m.assetRef || '';\n    const makeName = m.makeName || '';\n    const modelName = m.modelName || '';\n    const serial = m.serial || '';\n    const itemType = m.itemType || '';\n\n    const html =\n      '<div class=\"title\">' + escHtml(assetRef) + ' — ' + escHtml(makeName) + ' ' + escHtml(modelName) + ' | Serial: ' + escHtml(serial) + '</div>' +\n      '<div class=\"subtitle\">' + escHtml(itemType) + ' — Pre-Inventory Assessment</div>';\n\n    document.getElementById('root').innerHTML = html;\n  }\n\n  function initWhenReady() {\n    if (typeof appsmith === 'undefined' || !appsmith.onReady) {\n      setTimeout(initWhenReady, 50);\n      return;\n    }\n    appsmith.onReady(() => render(appsmith.model));\n    appsmith.onModelChange(() => render(appsmith.model));\n  }\n\n  initWhenReady();\n</script>",
    "js": ""
  },
  "theme": "{{appsmith.theme}}",
