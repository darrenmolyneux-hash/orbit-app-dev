  "defaultModel": "{{\n  {\n    removedParts: qry_get_asset_parts_combined.data.filter(r => r.row_status === 'removed') || [],\n    repairScraps: qry_repair_scraps.data || [],\n    step: appsmith.store.harvest_step,\n    isBattery: appsmith.store.hp_is_battery,\n    harvestSigned: appsmith.store.harvest_signed,\n    locationOptions: JSParts.locationOptions(),\n    donorLocationOptions: JSParts.donorLocationOptions(),\n    disposeByDate: JSParts.disposeByDate(),\n    signOffLabel: JSParts.signOffLabel(),\n    itemPartType: appsmith.store.hp_part_type,\n    sourceAssetRef: qry_GetAssetById.data[0]?.asset_ref\n  }\n}}",
