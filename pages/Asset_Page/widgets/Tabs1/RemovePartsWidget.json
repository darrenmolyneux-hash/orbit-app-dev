  "onResetClick": "{{showAlert('Successfully reset!!', '');}}",
  "onSignOff": "{{JSParts.signOff();}}",
  "onStep2to3": "{{JSParts.step2to3();}}",
  "onStep3to4": "{{JSParts.step3to4();}}",
  "onSubmitRemoval": "{{JSParts.submit();}}",
  "onWizardBack": "{{JSParts.onWizardBack();}}",
