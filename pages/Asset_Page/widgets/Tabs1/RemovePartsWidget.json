  "shouldScrollContents": true,
  "srcDoc": {
    "css": "",
    "html": "<!-- New custom widget: RemovePartsWidget. Replaces Custom6, tbl_parts_stock, con_harvest_workflow native widgets. -->\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Figtree:wght@400;600;700&display=swap');\n  * { box-sizing: border-box; font-family: 'Figtree', sans-serif; margin: 0; padding: 0; }\n\n  .wrap { display: flex; flex-direction: column; gap: 16px; }\n\n  .card { background: #fff; border-radius: 10px; border: 0.5px solid rgba(0,0,0,0.1); overflow: hidden; }\n  .card-header { padding: 14px 16px; display: flex; align-items: center; justify-content: space-between; border-bottom: 0.5px solid rgba(0,0,0,0.08); }\n  .card-title { font-size: 11px; font-weight: 700; color: #888780; text-transform: uppercase; letter-spacing: 0.06em; }\n  .card-count { font-size: 11px; font-weight: 600; color: #888780; }\n\n  table { width: 100%; border-collapse: collapse; }\n  th { text-align: left; padding: 8px 14px; font-size: 10px; font-weight: 700; color: #888780; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 0.5px solid rgba(0,0,0,0.08); }\n  td { padding: 10px 14px; font-size: 12px; font-weight: 600; color: #05042E; border-bottom: 0.5px solid rgba(0,0,0,0.06); }\n  tr:last-child td { border-bottom: none; }\n  tr:hover td { background: #f9f8f6; }\n  .empty-row td { text-align: center; color: #888780; font-weight: 500; padding: 20px; }\n\n  .grade-pill { font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 20px; background: rgba(5,4,46,0.06); color: #05042E; }\n  .part-ref-pill { font-family: monospace; font-size: 11px; font-weight: 700; color: #085041; background: #E1F5EE; padding: 2px 8px; border-radius: 4px; }\n  .dest-badge { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.03em; padding: 3px 10px; border-radius: 20px; white-space: nowrap; display: inline-block; }\n  .dest-badge.scrap-weee { background: #fee2e2; color: #b91c1c; }\n  .dest-badge.scrap-general { background: #FAEEDA; color: #633806; }\n  .dest-badge.stock { background: #E1F5EE; color: #085041; }\n  .dest-badge.asset { background: #E3EFF6; color: #1B4F6C; }\n  .overdue-badge { font-size: 10px; font-weight: 700; padding: 3px 10px; border-radius: 20px; background: #fee2e2; color: #b91c1c; }\n  .location-cell { font-size: 11px; font-weight: 500; color: #888780; }\n\n  .wizard-header { text-align: center; font-size: 15px; font-weight: 700; color: #085041; padding: 16px 16px 4px; }\n  .wizard-sub { text-align: center; font-size: 12px; color: #888780; padding-bottom: 12px; }\n\n  .step-body { padding: 16px; }\n  .field-row { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 14px; }\n  .fg { flex: 1; min-width: 160px; display: flex; flex-direction: column; gap: 4px; }\n  label { font-size: 10px; font-weight: 700; color: #888780; text-transform: uppercase; letter-spacing: 0.05em; }\n  input[type=\"text\"], input[type=\"number\"], select, textarea {\n    font-family: 'Figtree', sans-serif; font-size: 13px; font-weight: 600; color: #05042E;\n    border: 0.5px solid rgba(0,0,0,0.15); border-radius: 6px; padding: 8px 10px; outline: none; background: #fff; height: 36px;\n  }\n  textarea { height: auto; resize: vertical; font-weight: 500; }\n  input:focus, select:focus, textarea:focus { border-color: #469BC0; }\n\n  .battery-box { background: #FAEEDA; border: 0.5px solid #f5deb0; border-radius: 8px; padding: 14px 16px; margin-top: 12px; }\n  .battery-title { font-size: 12px; font-weight: 700; color: #633806; margin-bottom: 4px; }\n  .battery-sub { font-size: 11px; color: #633806; margin-bottom: 12px; }\n  .checklist-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px 20px; }\n  .check-row { display: flex; align-items: center; gap: 8px; font-size: 12px; font-weight: 600; color: #05042E; }\n  .check-row input { width: 15px; height: 15px; accent-color: #633806; }\n\n  .dest-note { background: rgba(70,155,192,0.08); border: 0.5px solid rgba(70,155,192,0.2); border-radius: 6px; padding: 10px 14px; font-size: 12px; font-weight: 600; color: #1B4F6C; margin-bottom: 14px; }\n  .disposal-note { text-align: center; font-size: 12px; font-weight: 700; color: #633806; margin-bottom: 14px; }\n\n  .confirm-tile-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-bottom: 20px; }\n  .confirm-tile { background: rgba(5,4,46,0.03); border-radius: 8px; padding: 12px 14px; display: flex; flex-direction: column; gap: 4px; }\n  .confirm-tile-label { font-size: 10px; font-weight: 700; color: #888780; text-transform: uppercase; letter-spacing: 0.05em; }\n  .confirm-tile-value { font-size: 14px; font-weight: 700; color: #05042E; }\n  .confirm-tile-warn { background: #FAEEDA; }\n  .confirm-tile-warn .confirm-tile-label { color: #633806; }\n  .confirm-tile-warn .confirm-tile-value { color: #633806; }\n\n  .signoff-notice {\n    font-size: 12px; font-weight: 700; color: #1B4F6C;\n    background: #E3EFF6; border: 0.5px solid rgba(70,155,192,0.3);\n    border-radius: 8px; padding: 10px 14px; margin-bottom: 14px;\n  }\n  .signoff-notice-done { background: #E1F5EE; color: #085041; border-color: rgba(163,232,81,0.4); }\n\n  .signoff-row { display: flex; justify-content: center; margin-bottom: 4px; }\n\n  .btn-row { display: flex; justify-content: space-between; align-items: center; gap: 10px; padding-top: 4px; }\n  .btn { font-family: 'Figtree', sans-serif; font-size: 12px; font-weight: 700; padding: 0 18px; height: 36px; border-radius: 6px; border: none; cursor: pointer; white-space: nowrap; }\n  .btn-primary { background: #A3E851; color: #05042E; }\n  .btn-primary:hover { background: #5DC987; }\n  .btn-primary:disabled { background: #E0DFE1; color: #aaa; cursor: not-allowed; }\n  .btn-secondary { background: rgba(5,4,46,0.06); color: #05042E; }\n  .btn-secondary:hover { background: rgba(5,4,46,0.1); }\n  .btn-signed { background: #E1F5EE; color: #085041; }\n\n  .status-note { font-size: 12px; font-weight: 600; color: #888780; text-align: center; padding: 8px 0; }\n</style>\n\n<div class=\"wrap\" id=\"root\"></div>\n\n<script>\n  function escHtml(str) {\n    if (str === null || str === undefined) return '';\n    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');\n  }\n\n  function fmtMoney(v) {\n    if (v === null || v === undefined || isNaN(v)) return '—';\n    return '£' + Number(v).toFixed(2);\n  }\n\n  // ---- local form state for the wizard ----\n  var formState = {\n    serial: '', condition_grade: '', notes: '',\n    c1: false, c2: false, c3: false, c4: false, c5: false, c6: false, voltage: '',\n    dest_type: '', dest_location: ''\n  };\n\n  function pushForm() {\n    appsmith.updateModel({ formData: formState });\n  }\n\n  function destBadge(type) {\n    if (!type) return '—';\n    if (type === 'scrap_weee') return '<span class=\"dest-badge scrap-weee\">WEEE Scrap</span>';\n    if (type.indexOf('scrap') === 0) return '<span class=\"dest-badge scrap-general\">Scrap</span>';\n    if (type === 'stock') return '<span class=\"dest-badge stock\">Stock</span>';\n    if (type === 'asset') return '<span class=\"dest-badge asset\">Asset</span>';\n    return '<span class=\"dest-badge stock\">' + escHtml(type) + '</span>';\n  }\n\n  function fmtDateShort(str) {\n    if (!str) return '—';\n    var d = new Date(str);\n    if (isNaN(d.getTime())) return String(str);\n    return d.toLocaleDateString('en-GB', { day: '2-digit', month: '2-digit', year: '2-digit' });\n  }\n\n  function renderTables(model) {\n    const removed = model.removedParts || [];\n    const scraps = model.repairScraps || [];\n\n    let html = '';\n\n    html += '<div class=\"card\"><div class=\"card-header\"><span class=\"card-title\">Removed Parts</span><span class=\"card-count\">' + removed.length + ' parts</span></div><table><thead><tr><th>Ref</th><th>Part Type</th><th>Make/Model</th><th>Serial</th><th>Grade</th><th>Destination</th><th>Location</th><th>Removed</th><th>Dispose By</th></tr></thead><tbody>';\n    if (!removed.length) {\n      html += '<tr class=\"empty-row\"><td colspan=\"9\">No parts removed yet</td></tr>';\n    } else {\n      removed.forEach(function(r) {\n        const makeModel = [r.part_make, r.part_model].filter(Boolean).join(' · ') || '—';\n        const location = r.installed_in_ref\n          ? 'In: ' + escHtml(r.installed_in_ref)\n          : (r.current_location_code ? escHtml(r.current_location_code + ' — ' + r.current_location_name) : '—');\n        const overdue = r.is_overdue\n          ? '<span class=\"overdue-badge\">Overdue</span>'\n          : (r.disposition_due ? fmtDateShort(r.disposition_due) : '—');\n        const battery = r.is_battery ? ' 🔋' : '';\n        html += '<tr>' +\n          '<td><span class=\"part-ref-pill\">' + escHtml(r.part_ref || '—') + '</span></td>' +\n          '<td>' + escHtml(r.part_type || '—') + battery + '</td>' +\n          '<td>' + escHtml(makeModel) + '</td>' +\n          '<td style=\"font-family:monospace;font-size:11px\">' + escHtml(r.serial_number || '—') + '</td>' +\n          '<td>' + (r.condition_grade ? '<span class=\"grade-pill\">' + escHtml(r.condition_grade) + '</span>' : '—') + '</td>' +\n          '<td>' + destBadge(r.destination_type) + '</td>' +\n          '<td class=\"location-cell\">' + location + '</td>' +\n          '<td style=\"font-size:11px\">' + fmtDateShort(r.removed_date) + '</td>' +\n          '<td style=\"font-size:11px\">' + overdue + '</td>' +\n          '</tr>';\n      });\n    }\n    html += '</tbody></table></div>';\n\n    html += '<div class=\"card\"><div class=\"card-header\"><span class=\"card-title\">Repair Scraps</span><span class=\"card-count\">' + scraps.length + ' logged</span></div><table><thead><tr><th>Ref</th><th>Part Type</th><th>Fault / Notes</th><th>Removed By</th><th>Date</th><th>Destination</th></tr></thead><tbody>';\n    if (!scraps.length) {\n      html += '<tr class=\"empty-row\"><td colspan=\"6\">No repair scraps logged</td></tr>';\n    } else {\n      scraps.forEach(function(r) {\n        html += '<tr>' +\n          '<td><span class=\"part-ref-pill\">' + escHtml(r.part_ref || '—') + '</span></td>' +\n          '<td>' + escHtml(r.part_type || '—') + '</td>' +\n          '<td class=\"location-cell\">' + escHtml(r.removal_notes || '—') + '</td>' +\n          '<td style=\"font-size:11px\">' + escHtml(r.removed_by || '—') + '</td>' +\n          '<td style=\"font-size:11px\">' + fmtDateShort(r.removed_date) + '</td>' +\n          '<td>' + destBadge(r.destination_type) + '</td>' +\n          '</tr>';\n      });\n    }\n    html += '</tbody></table></div>';\n\n    return html;\n  }\n\n  function renderWizard(model) {\n    const step = model.step || 0;\n    const isBattery = !!model.isBattery;\n    const locationOptions = model.locationOptions || [];\n    const donorLocationOptions = model.donorLocationOptions || [];\n    const disposeByDate = model.disposeByDate || '';\n    const signOffLabel = model.signOffLabel || 'Sign off as technician';\n    const harvestSigned = !!model.harvestSigned;\n    const confirmDisabled = !harvestSigned;\n\n    if (step === 0) {\n      return '<div class=\"card\"><div class=\"status-note\">Select \"View All Parts\" to start the part removal process.</div></div>';\n    }\n\n    let inner = '';\n\n    if (step === 2) {\n      inner = '<div class=\"wizard-header\">Serialise &amp; inspect</div>' +\n        '<div class=\"step-body\">' +\n        '<div class=\"field-row\">' +\n        '<div class=\"fg\"><label>Serial <span style=\"color:#dc2626\">*</span></label><input type=\"text\" id=\"fld_serial\" placeholder=\"Scan or type S/N\" value=\"' + escHtml(formState.serial) + '\"/></div>' +\n        '<div class=\"fg\"><label>Condition grade <span style=\"color:#dc2626\">*</span></label><select id=\"fld_condition\"><option value=\"\">Select option</option>' +\n        ['A','B','C','D','Scrap'].map(function(g) { return '<option value=\"' + g + '\"' + (formState.condition_grade === g ? ' selected' : '') + '>' + g + '</option>'; }).join('') +\n        '</select></div>' +\n        '<div class=\"fg\"><label>Notes</label><input type=\"text\" id=\"fld_notes\" placeholder=\"Any observations about the part condition\" value=\"' + escHtml(formState.notes) + '\"/></div>' +\n        '</div>';\n\n      if (isBattery) {\n        inner += '<div class=\"battery-box\">' +\n          '<div class=\"battery-title\">⚠ R2V3 Battery Checklist — all items must be checked</div>' +\n          '<div class=\"battery-sub\">Batteries require a documented safety inspection before removal per R2V3</div>' +\n          '<div class=\"checklist-grid\">' +\n          '<label class=\"check-row\"><input type=\"checkbox\" id=\"chk_c1\" ' + (formState.c1 ? 'checked' : '') + '/> Battery visually inspected — no swelling observed</label>' +\n          '<label class=\"check-row\"><input type=\"checkbox\" id=\"chk_c2\" ' + (formState.c2 ? 'checked' : '') + '/> No leakage observed</label>' +\n          '<label class=\"check-row\"><input type=\"checkbox\" id=\"chk_c3\" ' + (formState.c3 ? 'checked' : '') + '/> No physical damage to casing</label>' +\n          '<label class=\"check-row\"><input type=\"checkbox\" id=\"chk_c4\" ' + (formState.c4 ? 'checked' : '') + '/> Voltage measured and recorded</label>' +\n          '<label class=\"check-row\"><input type=\"checkbox\" id=\"chk_c5\" ' + (formState.c5 ? 'checked' : '') + '/> Check fire safety</label>' +\n          '<label class=\"check-row\"><input type=\"checkbox\" id=\"chk_c6\" ' + (formState.c6 ? 'checked' : '') + '/> WEEE-registered recycler stream confirmed</label>' +\n          '</div>' +\n          '<div class=\"fg\" style=\"margin-top:10px;max-width:160px;\"><label>Voltage reading (V)</label><input type=\"text\" id=\"fld_voltage\" placeholder=\"e.g. 11.4\" value=\"' + escHtml(formState.voltage) + '\"/></div>' +\n          '</div>';\n      }\n\n      inner += '<div class=\"btn-row\" style=\"margin-top:14px;justify-content:flex-end;\"><button class=\"btn btn-primary\" id=\"btn_next_23\">Next →</button></div>';\n      inner += '</div>';\n    }\n\n    if (step === 3) {\n      inner = '<div class=\"wizard-header\">Assign destination</div>' +\n        '<div class=\"step-body\">' +\n        '<div class=\"dest-note\">The source asset will be permanently recorded on this part and cannot be changed.</div>' +\n        (disposeByDate ? '<div class=\"disposal-note\">12-month disposal deadline: ' + escHtml(disposeByDate) + '</div>' : '') +\n        '<div class=\"field-row\">' +\n        '<div class=\"fg\"><label>Destination type</label><select id=\"fld_dest_type\"><option value=\"\">Select option</option>' +\n        '<option value=\"stock\"' + (formState.dest_type === 'stock' ? ' selected' : '') + '>Stock</option>' +\n        '<option value=\"scrap_weee\"' + (formState.dest_type === 'scrap_weee' ? ' selected' : '') + '>Scrap — WEEE</option>' +\n        '<option value=\"scrap_general\"' + (formState.dest_type === 'scrap_general' ? ' selected' : '') + '>Scrap — General</option>' +\n        '</select></div>' +\n        '<div class=\"fg\"><label>Location</label><select id=\"fld_dest_location\"><option value=\"\">Select option</option>' +\n        locationOptions.map(function(l) { return '<option value=\"' + escHtml(l.value) + '\"' + (formState.dest_location === l.value ? ' selected' : '') + '>' + escHtml(l.label) + '</option>'; }).join('') +\n        '</select></div>' +\n        '</div>' +\n        '<div class=\"btn-row\"><button class=\"btn btn-secondary\" id=\"btn_back_32\">← Back</button><button class=\"btn btn-primary\" id=\"btn_next_34\">Next — confirm →</button></div>' +\n        '</div>';\n    }\n\n    if (step === 4) {\n      const disposeByLine = disposeByDate ? escHtml(disposeByDate) : '—';\n      inner = '<div class=\"wizard-header\">Confirm &amp; sign off</div>' +\n        '<div class=\"step-body\">' +\n        '<div class=\"confirm-tile-grid\">' +\n        '<div class=\"confirm-tile\"><span class=\"confirm-tile-label\">Part Type</span><span class=\"confirm-tile-value\">' + escHtml(model.itemPartType || '—') + '</span></div>' +\n        '<div class=\"confirm-tile\"><span class=\"confirm-tile-label\">Serial</span><span class=\"confirm-tile-value\">' + escHtml(formState.serial || '—') + '</span></div>' +\n        '<div class=\"confirm-tile\"><span class=\"confirm-tile-label\">Source Asset</span><span class=\"confirm-tile-value\">' + escHtml(model.sourceAssetRef || '—') + '</span></div>' +\n        '<div class=\"confirm-tile\"><span class=\"confirm-tile-label\">Destination</span><span class=\"confirm-tile-value\">' + escHtml(formState.dest_type || '—') + '</span></div>' +\n        '<div class=\"confirm-tile\"><span class=\"confirm-tile-label\">Condition</span><span class=\"confirm-tile-value\">' + escHtml(formState.condition_grade || '—') + '</span></div>' +\n        '<div class=\"confirm-tile confirm-tile-warn\"><span class=\"confirm-tile-label\">Dispose By</span><span class=\"confirm-tile-value\">' + disposeByLine + '</span></div>' +\n        '</div>' +\n        (!harvestSigned\n          ? '<div class=\"signoff-notice\">✍️ A technician must sign off below before this removal can be confirmed and logged.</div>'\n          : '<div class=\"signoff-notice signoff-notice-done\">✓ Signed off by ' + escHtml(signOffLabel.replace('✓ Signed: ', '')) + ' — ready to confirm.</div>'\n        ) +\n        '<div class=\"signoff-row\">' +\n        '<button class=\"btn ' + (harvestSigned ? 'btn-signed' : 'btn-primary') + '\" id=\"btn_signoff\">' + (harvestSigned ? '✓ Signed off' : '✍️ Sign off as technician') + '</button>' +\n        '</div>' +\n        '<div class=\"btn-row\" style=\"margin-top:14px;\">' +\n        '<button class=\"btn btn-secondary\" id=\"btn_back_43\">← Back</button>' +\n        '<button class=\"btn btn-primary\" id=\"btn_confirm\" ' + (confirmDisabled ? 'disabled' : '') + '>Confirm removal &amp; log ✓</button>' +\n        '</div>' +\n        '</div>';\n    }\n\n    if (step === 5) {\n      inner = '<div class=\"status-note\" style=\"padding:24px;\">✓ Part removed and logged successfully.</div>';\n    }\n\n    return '<div class=\"card\">' + inner + '</div>';\n  }\n\n  function wireEvents(model) {\n    const serialInput = document.getElementById('fld_serial');\n    if (serialInput) serialInput.addEventListener('input', function() { formState.serial = this.value; });\n\n    const conditionSelect = document.getElementById('fld_condition');\n    if (conditionSelect) conditionSelect.addEventListener('change', function() { formState.condition_grade = this.value; });\n\n    const notesInput = document.getElementById('fld_notes');\n    if (notesInput) notesInput.addEventListener('input', function() { formState.notes = this.value; });\n\n    const voltageInput = document.getElementById('fld_voltage');\n    if (voltageInput) voltageInput.addEventListener('input', function() { formState.voltage = this.value; });\n\n    ['c1','c2','c3','c4','c5','c6'].forEach(function(key) {\n      const el = document.getElementById('chk_' + key);\n      if (el) el.addEventListener('change', function() { formState[key] = this.checked; });\n    });\n\n    const nextBtn23 = document.getElementById('btn_next_23');\n    if (nextBtn23) nextBtn23.addEventListener('click', function() {\n      pushForm();\n      appsmith.triggerEvent('onStep2to3');\n    });\n\n    const destType = document.getElementById('fld_dest_type');\n    if (destType) destType.addEventListener('change', function() { formState.dest_type = this.value; });\n\n    const destLocation = document.getElementById('fld_dest_location');\n    if (destLocation) destLocation.addEventListener('change', function() { formState.dest_location = this.value; });\n\n    const backBtn32 = document.getElementById('btn_back_32');\n    if (backBtn32) backBtn32.addEventListener('click', function() {\n      appsmith.updateModel({ backTo: 2 });\n      appsmith.triggerEvent('onWizardBack');\n    });\n\n    const nextBtn34 = document.getElementById('btn_next_34');\n    if (nextBtn34) nextBtn34.addEventListener('click', function() {\n      pushForm();\n      appsmith.triggerEvent('onStep3to4');\n    });\n\n    const backBtn43 = document.getElementById('btn_back_43');\n    if (backBtn43) backBtn43.addEventListener('click', function() {\n      appsmith.updateModel({ backTo: 3 });\n      appsmith.triggerEvent('onWizardBack');\n    });\n\n    const signOffBtn = document.getElementById('btn_signoff');\n    if (signOffBtn) signOffBtn.addEventListener('click', function() {\n      appsmith.triggerEvent('onSignOff');\n    });\n\n    const confirmBtn = document.getElementById('btn_confirm');\n    if (confirmBtn) confirmBtn.addEventListener('click', function() {\n      appsmith.triggerEvent('onSubmitRemoval');\n    });\n  }\n\n  function render(model) {\n    const m = model || {};\n    const root = document.getElementById('root');\n    root.innerHTML = renderTables(m) + renderWizard(m);\n    wireEvents(m);\n  }\n\n  function initWhenReady() {\n    if (typeof appsmith === 'undefined' || !appsmith.onReady) {\n      setTimeout(initWhenReady, 50);\n      return;\n    }\n    appsmith.onReady(() => render(appsmith.model));\n    appsmith.onModelChange(() => render(appsmith.model));\n  }\n\n  initWhenReady();\n</script>",
