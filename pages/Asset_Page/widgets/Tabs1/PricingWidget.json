    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<!-- Paste this into the custom widget's \"Edit source\" HTML/JS editor -->\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js\"></script>\n\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Figtree:wght@400;600;700&display=swap');\n\n  * { box-sizing: border-box; font-family: 'Figtree', sans-serif; }\n\n  .pricing-wrap { display: flex; flex-direction: column; gap: 16px; padding: 4px; }\n\n  /* Stat row */\n  .stat-row { display: flex; gap: 12px; flex-wrap: wrap; }\n  .stat-card {\n    flex: 1; min-width: 160px;\n    background: #fff;\n    border-radius: 10px;\n    border: 0.5px solid rgba(0,0,0,0.1);\n    padding: 14px 16px;\n    display: flex; align-items: center; gap: 10px;\n  }\n  .stat-icon {\n    width: 26px; height: 26px; border-radius: 8px;\n    background: rgba(5,4,46,0.1);\n    display: flex; align-items: center; justify-content: center;\n    flex-shrink: 0;\n  }\n  .stat-icon svg { width: 14px; height: 14px; }\n  .stat-label {\n    font-size: 10px; font-weight: 700; text-transform: uppercase;\n    color: #888780; letter-spacing: 0.05em; margin-bottom: 2px;\n  }\n  .stat-value { font-size: 15px; font-weight: 700; color: #05042E; }\n  .stat-sub { font-size: 10px; color: #888780; margin-top: 1px; }\n\n  /* Card container */\n  .card {\n    background: #fff;\n    border-radius: 10px;\n    border: 0.5px solid rgba(0,0,0,0.1);\n    padding: 16px;\n  }\n  .card-title {\n    font-size: 10px; font-weight: 700; text-transform: uppercase;\n    color: #888780; letter-spacing: 0.05em; margin-bottom: 12px;\n  }\n\n  /* Grade table */\n  table.grade-table { width: 100%; border-collapse: collapse; }\n  table.grade-table th {\n    text-align: left; font-size: 10px; font-weight: 700; text-transform: uppercase;\n    color: #888780; letter-spacing: 0.05em; padding: 6px 8px;\n    border-bottom: 1px solid rgba(0,0,0,0.08);\n  }\n  table.grade-table td {\n    font-size: 13px; font-weight: 600; color: #05042E;\n    padding: 8px; border-bottom: 1px solid rgba(0,0,0,0.05);\n  }\n  .grade-pill {\n    display: inline-block; font-size: 10px; font-weight: 700; text-transform: uppercase;\n    padding: 3px 10px; border-radius: 20px;\n  }\n  .grade-A { background: #E1F5EE; color: #085041; }\n  .grade-B { background: #E1F5EE; color: #085041; }\n  .grade-C { background: #FAEEDA; color: #633806; }\n  .grade-D { background: #fee2e2; color: #991b1b; }\n\n  .empty-state {\n    font-size: 12px; color: #888780; text-align: center; padding: 24px 0;\n  }\n\n  .chart-container { position: relative; height: 220px; width: 100%; }\n</style>\n\n<div class=\"pricing-wrap\">\n\n  <!-- Stat cards -->\n  <div class=\"stat-row\">\n    <div class=\"stat-card\">\n      <div class=\"stat-icon\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#05042E\" stroke-width=\"2\"><path d=\"M12 1v22M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6\"/></svg>\n      </div>\n      <div>\n        <div class=\"stat-label\">Avg Paid (6mo)</div>\n        <div class=\"stat-value\" id=\"avgPaid\">—</div>\n      </div>\n    </div>\n    <div class=\"stat-card\">\n      <div class=\"stat-icon\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#05042E\" stroke-width=\"2\"><path d=\"M3 3v18h18M7 14l4-4 3 3 5-6\"/></svg>\n      </div>\n      <div>\n        <div class=\"stat-label\">Avg Sold (6mo)</div>\n        <div class=\"stat-value\" id=\"avgSold\">—</div>\n      </div>\n    </div>\n    <div class=\"stat-card\">\n      <div class=\"stat-icon\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#05042E\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"9\"/><path d=\"M12 7v5l3 3\"/></svg>\n      </div>\n      <div>\n        <div class=\"stat-label\">Estimated Value</div>\n        <div class=\"stat-value\" id=\"estValue\">—</div>\n        <div class=\"stat-sub\" id=\"estValueSub\"></div>\n      </div>\n    </div>\n  </div>\n\n  <!-- Grade breakdown table -->\n  <div class=\"card\">\n    <div class=\"card-title\">Grade Breakdown — Last 6 Months</div>\n    <table class=\"grade-table\" id=\"gradeTable\">\n      <thead>\n        <tr>\n          <th>Grade</th>\n          <th>Units Paid</th>\n          <th>Avg Paid</th>\n          <th>Units Sold</th>\n          <th>Avg Sold</th>\n        </tr>\n      </thead>\n      <tbody id=\"gradeTableBody\"></tbody>\n    </table>\n    <div class=\"empty-state\" id=\"gradeEmpty\" style=\"display:none;\">No pricing data for this make/model in the last 6 months.</div>\n  </div>\n\n  <!-- Trend chart -->\n  <div class=\"card\">\n    <div class=\"card-title\">Sale Price Trend by Grade</div>\n    <div class=\"chart-container\">\n      <canvas id=\"trendChart\"></canvas>\n    </div>\n    <div class=\"empty-state\" id=\"trendEmpty\" style=\"display:none;\">Not enough sale history to show a trend yet.</div>\n  </div>\n\n</div>\n\n<script>\n  let chartInstance = null;\n\n  const gradeColors = {\n    A: '#5DC987',\n    B: '#A3E851',\n    C: '#469BC0',\n    D: '#888780'\n  };\n\n  function fmtMoney(v) {\n    if (v === null || v === undefined || isNaN(v)) return '—';\n    return '£' + Number(v).toLocaleString('en-GB', { minimumFractionDigits: 2, maximumFractionDigits: 2 });\n  }\n\n  function render(model) {\n    const purchase = model.purchaseHistory || [];\n    const sale = model.saleHistory || [];\n    const trend = model.priceTrend || [];\n    const est = (model.estimatedValue && model.estimatedValue[0]) || null;\n\n    // Stat cards\n    const totalPaidUnits = purchase.reduce((s, r) => s + Number(r.units || 0), 0);\n    const weightedPaid = purchase.reduce((s, r) => s + (Number(r.avg_paid || 0) * Number(r.units || 0)), 0);\n    document.getElementById('avgPaid').innerText = totalPaidUnits ? fmtMoney(weightedPaid / totalPaidUnits) : '—';\n\n    const totalSoldUnits = sale.reduce((s, r) => s + Number(r.units_sold || 0), 0);\n    const weightedSold = sale.reduce((s, r) => s + (Number(r.avg_sold || 0) * Number(r.units_sold || 0)), 0);\n    document.getElementById('avgSold').innerText = totalSoldUnits ? fmtMoney(weightedSold / totalSoldUnits) : '—';\n\n    if (est && est.sample_size > 0) {\n      document.getElementById('estValue').innerText = fmtMoney(est.estimated_value);\n      document.getElementById('estValueSub').innerText = 'based on ' + est.sample_size + ' sale' + (est.sample_size == 1 ? '' : 's') + ', this grade';\n    } else if (totalSoldUnits > 0) {\n      document.getElementById('estValue').innerText = fmtMoney(weightedSold / totalSoldUnits);\n      document.getElementById('estValueSub').innerText = 'based on all grades (no exact grade match)';\n    } else if (totalPaidUnits > 0) {\n      document.getElementById('estValue').innerText = fmtMoney(weightedPaid / totalPaidUnits);\n      document.getElementById('estValueSub').innerText = 'based on purchase cost (no sales yet)';\n    } else {\n      document.getElementById('estValue').innerText = '—';\n      document.getElementById('estValueSub').innerText = 'no data';\n    }\n\n    // Grade table — merge purchase + sale by grade\n    const grades = Array.from(new Set([...purchase.map(r => r.grade), ...sale.map(r => r.grade)])).sort();\n    const tbody = document.getElementById('gradeTableBody');\n    tbody.innerHTML = '';\n\n    if (grades.length === 0) {\n      document.getElementById('gradeEmpty').style.display = 'block';\n    } else {\n      document.getElementById('gradeEmpty').style.display = 'none';\n      grades.forEach(g => {\n        const p = purchase.find(r => r.grade === g) || {};\n        const s = sale.find(r => r.grade === g) || {};\n        const pillClass = 'grade-' + (g || 'D');\n        const row = document.createElement('tr');\n        row.innerHTML = `\n          <td><span class=\"grade-pill ${pillClass}\">${g || '—'}</span></td>\n          <td>${p.units || 0}</td>\n          <td>${fmtMoney(p.avg_paid)}</td>\n          <td>${s.units_sold || 0}</td>\n          <td>${fmtMoney(s.avg_sold)}</td>\n        `;\n        tbody.appendChild(row);\n      });\n    }\n\n    // Trend chart\n    renderChart(trend);\n  }\n\n  function renderChart(trend) {\n    const canvas = document.getElementById('trendChart');\n    const emptyEl = document.getElementById('trendEmpty');\n\n    if (!trend || trend.length === 0) {\n      canvas.style.display = 'none';\n      emptyEl.style.display = 'block';\n      if (chartInstance) { chartInstance.destroy(); chartInstance = null; }\n      return;\n    }\n    canvas.style.display = 'block';\n    emptyEl.style.display = 'none';\n\n    const months = Array.from(new Set(trend.map(r => r.month))).sort();\n    const grades = Array.from(new Set(trend.map(r => r.grade))).sort();\n\n    const datasets = grades.map(g => ({\n      label: 'Grade ' + g,\n      data: months.map(m => {\n        const row = trend.find(r => r.month === m && r.grade === g);\n        return row ? Number(row.avg_sold) : null;\n      }),\n      borderColor: gradeColors[g] || '#469BC0',\n      backgroundColor: gradeColors[g] || '#469BC0',\n      tension: 0.35,\n      spanGaps: true,\n      pointRadius: 3,\n      borderWidth: 2\n    }));\n\n    const labels = months.map(m => new Date(m).toLocaleDateString('en-GB', { month: 'short', year: '2-digit' }));\n\n    if (chartInstance) chartInstance.destroy();\n    chartInstance = new Chart(canvas.getContext('2d'), {\n      type: 'line',\n      data: { labels, datasets },\n      options: {\n        responsive: true,\n        maintainAspectRatio: false,\n        plugins: {\n          legend: {\n            position: 'bottom',\n            labels: { font: { family: 'Figtree', size: 11, weight: '600' }, color: '#888780', boxWidth: 10, usePointStyle: true }\n          },\n          tooltip: {\n            callbacks: { label: (ctx) => ctx.dataset.label + ': £' + ctx.parsed.y.toFixed(2) }\n          }\n        },\n        scales: {\n          x: { ticks: { font: { family: 'Figtree', size: 10 }, color: '#888780' }, grid: { display: false } },\n          y: { ticks: { font: { family: 'Figtree', size: 10 }, color: '#888780', callback: (v) => '£' + v }, grid: { color: 'rgba(0,0,0,0.05)' } }\n        }\n      }\n    });\n  }\n\n  function initWhenReady() {\n    if (typeof appsmith === 'undefined' || !appsmith.onReady) {\n      setTimeout(initWhenReady, 50);\n      return;\n    }\n    appsmith.onReady(() => {\n      render(appsmith.model);\n    });\n    appsmith.onModelChange(() => {\n      render(appsmith.model);\n    });\n  }\n\n  initWhenReady();\n</script>",
    "js": "import React from \"https://esm.sh/react@18.2.0\";\nimport ReactDOM from \"https://esm.sh/react-dom@18.2.0\";\n\nconst Button = ({ children, className, ...props }) => (\n  <button className={className} {...props}>\n    {children}\n  </button>\n);\n\nfunction App() {\n  const [currentIndex, setCurrentIndex] = React.useState(0);\n\n  const handleNext = () => {\n    setCurrentIndex((prevIndex) => (prevIndex + 1) % appsmith.model.tips.length);\n  };\n\n  const handleReset = () => {\n    setCurrentIndex(0);\n    appsmith.triggerEvent(\"onResetClick\");\n  };\n\n  return (\n    <div className=\"app\">\n      <div className=\"tip-container\">\n        <div className=\"tip-header\">\n          <h2>Custom Widget</h2>\n          <div>{currentIndex + 1} / {appsmith.model.tips.length}</div>\n        </div>\n        <div className=\"content\">{appsmith.model.tips[currentIndex]}</div>\n      </div>\n      <div className=\"button-container\">\n        <Button className=\"primary\" onClick={handleNext}>Next Tip</Button>\n        <Button className=\"reset\" disabled={currentIndex === 0} onClick={handleReset}>Reset</Button>\n      </div>\n    </div>\n  );\n}\n\nappsmith.onReady(() => {\n/*\n\t * This handler function will get called when parent application is ready.\n\t * Initialize your component here\n\t * more info - https://docs.appsmith.com/reference/widgets/custom#onready\n\t */\n    ReactDOM.render(<App />, document.getElementById(\"root\"));\n});"
  },
  "version": 1,
  "widgetId": "9o8qohdtqc",
  "widgetName": "PricingWidget"
}