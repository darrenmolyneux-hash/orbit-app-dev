{
  "backgroundColor": "#FFFFFF",
  "borderColor": "#E0DEDE",
  "borderRadius": "{{appsmith.theme.borderRadius.appBorderRadius}}",
  "borderWidth": "1",
  "bottomRow": 21,
  "boxShadow": "{{appsmith.theme.boxShadow.appBoxShadow}}",
  "defaultModel": "{\n  \"partTypes\": [],\n  \"asset\": {}\n}",
  "dynamicBindingPathList": [
    {
      "key": "theme"
    },
    {
      "key": "borderRadius"
    },
    {
      "key": "boxShadow"
    },
    {
      "key": "isVisible"
    }
  ],
  "dynamicHeight": "FIXED",
  "dynamicPropertyPathList": [
    {
      "key": "isVisible"
    }
  ],
  "dynamicTriggerPathList": [
    {
      "key": "onPartAssessed"
    }
  ],
  "events": [
    "onPartAssessed"
  ],
  "isCanvas": false,
  "isLoading": false,
  "isSearchWildcard": true,
  "isVisible": "{{qry_GetAssetById.data[0].status_id === 15}}",
  "key": "af1n28l6vs",
  "leftColumn": 0,
  "maxDynamicHeight": 9000,
  "minDynamicHeight": 4,
  "mobileBottomRow": 21,
  "mobileLeftColumn": 17,
  "mobileRightColumn": 40,
  "mobileTopRow": 0,
  "needsErrorInfo": false,
  "onPartAssessed": "{{JSParts.savePreInventory();}}",
  "parentColumnSpace": 17.625,
  "parentId": "onlm3me0uv",
  "parentRowSpace": 10,
  "renderMode": "CANVAS",
  "rightColumn": 64,
  "srcDoc": {
    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Pre-Inventory Assessment</title>\n<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  \n  body {\n    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;\n    font-size: 13px;\n    color: #1a1a1a;\n    background: #ffffff;\n    padding: 0;\n  }\n\n  .widget {\n    padding: 16px;\n    border: 1px solid #e2e8f0;\n    border-radius: 10px;\n    background: #fff;\n  }\n\n  .widget-header {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    margin-bottom: 14px;\n    padding-bottom: 12px;\n    border-bottom: 1px solid #f1f5f9;\n  }\n\n  .widget-title {\n    font-size: 14px;\n    font-weight: 600;\n    color: #1A5C3A;\n    display: flex;\n    align-items: center;\n    gap: 7px;\n  }\n\n  .widget-title svg {\n    width: 18px;\n    height: 18px;\n    stroke: #1A5C3A;\n    fill: none;\n    stroke-width: 2;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  .asset-badge {\n    background: #f1f5f9;\n    border: 1px solid #e2e8f0;\n    border-radius: 6px;\n    padding: 4px 10px;\n    font-size: 11px;\n    color: #475569;\n  }\n\n  .instructions {\n    background: #EAF3DE;\n    border: 1px solid #97C459;\n    border-radius: 7px;\n    padding: 9px 12px;\n    font-size: 11px;\n    color: #27500A;\n    margin-bottom: 14px;\n    line-height: 1.5;\n  }\n\n  .instructions strong { font-weight: 600; }\n\n  .parts-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 6px;\n    margin-bottom: 14px;\n  }\n\n  .part-card {\n    border: 1.5px solid #e2e8f0;\n    border-radius: 8px;\n    padding: 9px 11px;\n    cursor: pointer;\n    transition: all 0.15s;\n    background: #fff;\n    position: relative;\n  }\n\n  .part-card:hover {\n    border-color: #94a3b8;\n    background: #f8fafc;\n  }\n\n  .part-card.is-scrap {\n    border-color: #fca5a5;\n    background: #fff5f5;\n  }\n\n  .part-card.is-battery {\n    border-color: #fbbf24;\n    background: #fffbeb;\n  }\n\n  .part-card.is-battery.is-scrap {\n    border-color: #fca5a5;\n    background: #fff5f5;\n  }\n\n  .part-card-top {\n    display: flex;\n    align-items: flex-start;\n    gap: 8px;\n  }\n\n  .scrap-checkbox {\n    width: 16px;\n    height: 16px;\n    border: 2px solid #cbd5e1;\n    border-radius: 4px;\n    flex-shrink: 0;\n    margin-top: 1px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: all 0.15s;\n    background: #fff;\n  }\n\n  .part-card.is-scrap .scrap-checkbox {\n    background: #ef4444;\n    border-color: #ef4444;\n  }\n\n  .scrap-checkbox svg {\n    width: 10px;\n    height: 10px;\n    stroke: #fff;\n    fill: none;\n    stroke-width: 3;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n    opacity: 0;\n  }\n\n  .part-card.is-scrap .scrap-checkbox svg { opacity: 1; }\n\n  .part-info { flex: 1; min-width: 0; }\n\n  .part-name {\n    font-size: 12px;\n    font-weight: 500;\n    color: #1e293b;\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n  }\n\n  .part-card.is-scrap .part-name { color: #ef4444; text-decoration: line-through; }\n\n  .battery-tag {\n    font-size: 9px;\n    background: #fef3c7;\n    color: #92400e;\n    border-radius: 99px;\n    padding: 1px 6px;\n    font-weight: 500;\n    display: inline-block;\n    margin-top: 2px;\n  }\n\n  .scrap-tag {\n    font-size: 9px;\n    background: #fee2e2;\n    color: #b91c1c;\n    border-radius: 99px;\n    padding: 1px 6px;\n    font-weight: 500;\n    display: inline-block;\n    margin-top: 2px;\n  }\n\n  .part-detail-row {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 5px;\n    margin-top: 7px;\n    padding-top: 7px;\n    border-top: 1px solid #f1f5f9;\n  }\n\n  .part-card.is-scrap .part-detail-row { border-top-color: #fecaca; }\n\n  .detail-group { display: flex; flex-direction: column; gap: 2px; }\n\n  .detail-label {\n    font-size: 9px;\n    color: #94a3b8;\n    font-weight: 500;\n    text-transform: uppercase;\n    letter-spacing: 0.04em;\n  }\n\n  .detail-input {\n    height: 26px;\n    border: 1px solid #e2e8f0;\n    border-radius: 5px;\n    padding: 0 7px;\n    font-size: 11px;\n    color: #1e293b;\n    background: #fff;\n    width: 100%;\n    outline: none;\n    transition: border-color 0.15s;\n  }\n\n  .detail-input:focus { border-color: #1A5C3A; }\n\n  .detail-select {\n    height: 26px;\n    border: 1px solid #e2e8f0;\n    border-radius: 5px;\n    padding: 0 5px;\n    font-size: 11px;\n    color: #1e293b;\n    background: #fff;\n    width: 100%;\n    outline: none;\n  }\n\n  .detail-select:focus { border-color: #1A5C3A; }\n\n  .notes-input {\n    width: 100%;\n    height: 32px;\n    border: 1px solid #e2e8f0;\n    border-radius: 5px;\n    padding: 4px 7px;\n    font-size: 11px;\n    color: #1e293b;\n    background: #fff;\n    outline: none;\n    resize: none;\n    font-family: inherit;\n  }\n\n  .notes-input:focus { border-color: #1A5C3A; }\n\n  .battery-warn {\n    background: #fffbeb;\n    border: 1px solid #fbbf24;\n    border-radius: 5px;\n    padding: 5px 8px;\n    font-size: 10px;\n    color: #92400e;\n    margin-top: 6px;\n    grid-column: 1 / -1;\n  }\n\n  .summary-bar {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n    padding: 8px 12px;\n    background: #f8fafc;\n    border: 1px solid #e2e8f0;\n    border-radius: 7px;\n    margin-bottom: 12px;\n    flex-wrap: wrap;\n  }\n\n  .summary-stat {\n    display: flex;\n    align-items: center;\n    gap: 5px;\n    font-size: 11px;\n  }\n\n  .stat-dot {\n    width: 8px;\n    height: 8px;\n    border-radius: 50%;\n  }\n\n  .dot-green { background: #22c55e; }\n  .dot-red { background: #ef4444; }\n  .dot-amber { background: #f59e0b; }\n\n  .submit-row {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 10px;\n    padding-top: 12px;\n    border-top: 1px solid #f1f5f9;\n  }\n\n  .submit-hint {\n    font-size: 11px;\n    color: #94a3b8;\n  }\n\n  .btn-submit {\n    height: 36px;\n    padding: 0 20px;\n    background: #1A5C3A;\n    color: #fff;\n    border: none;\n    border-radius: 7px;\n    font-size: 13px;\n    font-weight: 500;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    transition: opacity 0.15s;\n  }\n\n  .btn-submit:hover { opacity: 0.9; }\n  .btn-submit:disabled { opacity: 0.4; cursor: not-allowed; }\n\n  .btn-submit svg {\n    width: 15px;\n    height: 15px;\n    stroke: #fff;\n    fill: none;\n    stroke-width: 2.5;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  .success-flash {\n    display: none;\n    background: #E1F5EE;\n    border: 1px solid #5DCAA5;\n    border-radius: 7px;\n    padding: 10px 14px;\n    font-size: 12px;\n    color: #085041;\n    font-weight: 500;\n    text-align: center;\n    margin-bottom: 12px;\n  }\n\n  .empty-state {\n    text-align: center;\n    padding: 24px;\n    color: #94a3b8;\n    font-size: 12px;\n  }\n\n  .session-log {\n    margin-top: 12px;\n    padding-top: 12px;\n    border-top: 1px solid #f1f5f9;\n  }\n\n  .session-log-title {\n    font-size: 10px;\n    font-weight: 600;\n    color: #64748b;\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n    margin-bottom: 7px;\n  }\n\n  .log-item {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    padding: 5px 0;\n    border-bottom: 1px solid #f8fafc;\n    font-size: 11px;\n  }\n\n  .log-badge {\n    padding: 1px 7px;\n    border-radius: 99px;\n    font-size: 10px;\n    font-weight: 500;\n  }\n\n  .log-badge.salvage { background: #E1F5EE; color: #085041; }\n  .log-badge.scrap { background: #fee2e2; color: #b91c1c; }\n\n  @media (max-width: 500px) {\n    .parts-grid { grid-template-columns: 1fr; }\n  }\n</style>\n</head>\n<body>\n\n<div class=\"widget\">\n\n  <div class=\"widget-header\">\n    <div class=\"widget-title\">\n      <svg viewBox=\"0 0 24 24\"><path d=\"M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2\"/><rect x=\"9\" y=\"3\" width=\"6\" height=\"4\" rx=\"2\"/><path d=\"m9 12 2 2 4-4\"/></svg>\n      Part assessment\n    </div>\n    <div class=\"asset-badge\" id=\"assetBadge\">Loading asset...</div>\n  </div>\n\n  <div class=\"instructions\">\n    <strong>Tick any parts that are damaged or cannot be salvaged.</strong> All unticked parts will be logged as salvageable and available for removal. Ticked parts are logged as scrap.\n  </div>\n\n  <div class=\"success-flash\" id=\"successFlash\"></div>\n\n  <div class=\"summary-bar\" id=\"summaryBar\" style=\"display:none;\">\n    <div class=\"summary-stat\">\n      <div class=\"stat-dot dot-green\"></div>\n      <span id=\"statSalvage\">0 salvageable</span>\n    </div>\n    <div class=\"summary-stat\">\n      <div class=\"stat-dot dot-red\"></div>\n      <span id=\"statScrap\">0 scrap</span>\n    </div>\n    <div class=\"summary-stat\">\n      <div class=\"stat-dot dot-amber\"></div>\n      <span id=\"statBattery\">0 batteries</span>\n    </div>\n  </div>\n\n  <div id=\"partsGrid\" class=\"parts-grid\">\n    <div class=\"empty-state\">Loading parts for this device type...</div>\n  </div>\n\n  <div class=\"submit-row\">\n    <div class=\"submit-hint\" id=\"submitHint\">Select parts above then submit</div>\n    <button class=\"btn-submit\" id=\"btnSubmit\" onclick=\"submitAssessment()\" disabled>\n      <svg viewBox=\"0 0 24 24\"><polyline points=\"20 6 9 17 4 12\"/></svg>\n      Log all parts\n    </button>\n  </div>\n\n  <div class=\"session-log\" id=\"sessionLog\" style=\"display:none;\">\n    <div class=\"session-log-title\">Logged this session</div>\n    <div id=\"sessionLogItems\"></div>\n  </div>\n\n</div>\n\n<script>\n  let partTypes = [];\n  let partStates = {};\n  let assetData = {};\n  let sessionLog = [];\n\n  appsmith.onReady(() => {\n    const model = appsmith.model || {};\n    partTypes = model.partTypes || [];\n    assetData = model.asset || {};\n    renderAssetBadge();\n    renderParts();\n  });\n\n  appsmith.onModelChange((newModel) => {\n    partTypes = newModel.partTypes || [];\n    assetData = newModel.asset || {};\n    renderAssetBadge();\n    renderParts();\n  });\n\n  function renderAssetBadge() {\n    const badge = document.getElementById('assetBadge');\n    if (assetData.asset_tag) {\n      badge.textContent = assetData.asset_tag + ' — ' + (assetData.make || '') + ' ' + (assetData.model || '');\n    } else {\n      badge.textContent = 'Asset loading...';\n    }\n  }\n\n  function renderParts() {\n    const grid = document.getElementById('partsGrid');\n\n    if (!partTypes || partTypes.length === 0) {\n      grid.innerHTML = '<div class=\"empty-state\">No parts found for this device type. Check part type mappings.</div>';\n      return;\n    }\n\n    // Initialise state for any new parts\n    partTypes.forEach(pt => {\n      if (!partStates[pt.part_type_id]) {\n        partStates[pt.part_type_id] = {\n          part_type_id: pt.part_type_id,\n          name: pt.name,\n          is_battery: pt.is_battery,\n          is_scrap: false,\n          make: '',\n          model: '',\n          condition: 'B',\n          notes: ''\n        };\n      }\n    });\n\n    grid.innerHTML = partTypes.map(pt => {\n      const state = partStates[pt.part_type_id];\n      const isScrap = state.is_scrap;\n      const isBattery = pt.is_battery;\n\n      return `\n        <div class=\"part-card ${isScrap ? 'is-scrap' : ''} ${isBattery && !isScrap ? 'is-battery' : ''}\"\n             id=\"card_${pt.part_type_id}\"\n             onclick=\"toggleScrap(${pt.part_type_id}, event)\">\n          <div class=\"part-card-top\">\n            <div class=\"scrap-checkbox\">\n              <svg viewBox=\"0 0 12 12\"><polyline points=\"2 6 5 9 10 3\"/></svg>\n            </div>\n            <div class=\"part-info\">\n              <div class=\"part-name\">${pt.name}</div>\n              ${isBattery ? '<span class=\"battery-tag\">🔋 Battery — R2V3 checklist at removal</span>' : ''}\n              ${isScrap ? '<span class=\"scrap-tag\">Marked as scrap</span>' : ''}\n            </div>\n          </div>\n\n          <div class=\"part-detail-row\" onclick=\"event.stopPropagation()\">\n            <div class=\"detail-group\">\n              <div class=\"detail-label\">Make</div>\n              <input class=\"detail-input\"\n                     type=\"text\"\n                     placeholder=\"e.g. Samsung\"\n                     value=\"${state.make}\"\n                     onchange=\"updateField(${pt.part_type_id}, 'make', this.value)\"\n                     onclick=\"event.stopPropagation()\">\n            </div>\n            <div class=\"detail-group\">\n              <div class=\"detail-label\">Model / spec</div>\n              <input class=\"detail-input\"\n                     type=\"text\"\n                     placeholder=\"e.g. 512GB NVMe\"\n                     value=\"${state.model}\"\n                     onchange=\"updateField(${pt.part_type_id}, 'model', this.value)\"\n                     onclick=\"event.stopPropagation()\">\n            </div>\n            <div class=\"detail-group\">\n              <div class=\"detail-label\">Condition</div>\n              <select class=\"detail-select\"\n                      onchange=\"updateField(${pt.part_type_id}, 'condition', this.value)\"\n                      onclick=\"event.stopPropagation()\">\n                <option value=\"A\" ${state.condition === 'A' ? 'selected' : ''}>A — Excellent</option>\n                <option value=\"B\" ${state.condition === 'B' ? 'selected' : ''}>B — Good</option>\n                <option value=\"C\" ${state.condition === 'C' ? 'selected' : ''}>C — Fair</option>\n                <option value=\"F\" ${state.condition === 'F' ? 'selected' : ''}>F — Faulty</option>\n                <option value=\"U\" ${state.condition === 'U' ? 'selected' : ''}>U — Unknown</option>\n              </select>\n            </div>\n            <div class=\"detail-group\">\n              <div class=\"detail-label\">Notes</div>\n              <input class=\"detail-input\"\n                     type=\"text\"\n                     placeholder=\"Optional\"\n                     value=\"${state.notes}\"\n                     onchange=\"updateField(${pt.part_type_id}, 'notes', this.value)\"\n                     onclick=\"event.stopPropagation()\">\n            </div>\n            ${isBattery ? `\n            <div class=\"battery-warn\">\n              ⚠ R2V3 battery inspection checklist required when this part is physically removed.\n            </div>` : ''}\n          </div>\n        </div>\n      `;\n    }).join('');\n\n    updateSummary();\n    updateSubmitButton();\n    document.getElementById('summaryBar').style.display = 'flex';\n  }\n\n  function toggleScrap(partTypeId, event) {\n    if (event.target.tagName === 'INPUT' ||\n        event.target.tagName === 'SELECT' ||\n        event.target.tagName === 'TEXTAREA') return;\n\n    partStates[partTypeId].is_scrap = !partStates[partTypeId].is_scrap;\n    renderParts();\n  }\n\n  function updateField(partTypeId, field, value) {\n    partStates[partTypeId][field] = value;\n    updateSummary();\n    updateSubmitButton();\n  }\n\n  function updateSummary() {\n    const all = Object.values(partStates);\n    const salvage = all.filter(p => !p.is_scrap).length;\n    const scrap = all.filter(p => p.is_scrap).length;\n    const battery = all.filter(p => p.is_battery).length;\n\n    document.getElementById('statSalvage').textContent = salvage + ' salvageable';\n    document.getElementById('statScrap').textContent = scrap + ' scrap';\n    document.getElementById('statBattery').textContent = battery + (battery === 1 ? ' battery' : ' batteries');\n  }\n\n  function updateSubmitButton() {\n    const btn = document.getElementById('btnSubmit');\n    const hint = document.getElementById('submitHint');\n    const count = Object.values(partStates).length;\n\n    if (count > 0) {\n      btn.disabled = false;\n      const scrapCount = Object.values(partStates).filter(p => p.is_scrap).length;\n      hint.textContent = scrapCount > 0\n        ? scrapCount + ' part' + (scrapCount > 1 ? 's' : '') + ' marked as scrap'\n        : 'All parts marked as salvageable';\n    } else {\n      btn.disabled = true;\n      hint.textContent = 'No parts to log';\n    }\n  }\n\n  function submitAssessment() {\n    const parts = Object.values(partStates);\n    if (parts.length === 0) return;\n\n    const payload = parts.map(p => ({\n      part_type_id:  p.part_type_id,\n      part_type_name: p.name,\n      is_battery:    p.is_battery,\n      is_scrap:      p.is_scrap,\n      is_salvageable: !p.is_scrap,\n      make:          p.make || '',\n      model:         p.model || '',\n      condition:     p.is_scrap ? 'F' : p.condition,\n      notes:         p.notes || '',\n      status:        p.is_scrap ? 'scrapped' : 'in_asset'\n    }));\n\n    // Update session log display\n    payload.forEach(p => {\n      sessionLog.push({\n        name: p.part_type_name,\n        salvageable: p.is_salvageable,\n        condition: p.condition\n      });\n    });\n    renderSessionLog();\n\n    // Fire event to Appsmith with the full payload\n    appsmith.updateModel({ assessedParts: payload });\n    appsmith.triggerEvent('onPartAssessed');\n\n    // Show success flash\n    const salvageCount = payload.filter(p => p.is_salvageable).length;\n    const scrapCount = payload.filter(p => p.is_scrap).length;\n    const flash = document.getElementById('successFlash');\n    flash.textContent = `✓ ${payload.length} parts logged — ${salvageCount} salvageable, ${scrapCount} scrap`;\n    flash.style.display = 'block';\n    setTimeout(() => { flash.style.display = 'none'; }, 4000);\n\n    // Reset states for next session\n    partStates = {};\n    renderParts();\n  }\n\n  function renderSessionLog() {\n    const log = document.getElementById('sessionLog');\n    const items = document.getElementById('sessionLogItems');\n    log.style.display = 'block';\n\n    items.innerHTML = sessionLog.slice(-10).reverse().map(item => `\n      <div class=\"log-item\">\n        <span class=\"log-badge ${item.salvageable ? 'salvage' : 'scrap'}\">\n          ${item.salvageable ? 'Salvageable' : 'Scrap'}\n        </span>\n        <span>${item.name}</span>\n        <span style=\"color:#94a3b8;margin-left:auto;\">Grade ${item.condition}</span>\n      </div>\n    `).join('');\n  }\n</script>\n</body>\n</html>\n",
