    "html": "<!-- Paste into Custom7's source editor. Clear old Style/JS tabs after - this is self-contained. -->\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Figtree:wght@400;600;700&display=swap');\n  * { box-sizing: border-box; font-family: 'Figtree', sans-serif; margin: 0; padding: 0; }\n\n  .app { width: 100%; background: #fff; border-radius: 10px; padding: 16px 18px; border: 0.5px solid rgba(0,0,0,0.1); }\n\n  .header-row { display: flex; justify-content: space-between; align-items: flex-start; gap: 16px; flex-wrap: wrap; margin-bottom: 4px; }\n  .header-left { display: flex; align-items: center; gap: 8px; }\n  .header-icon { font-size: 16px; }\n  .header-title { font-size: 13px; font-weight: 700; color: #085041; }\n  .assessed-note { font-size: 11px; font-weight: 500; color: #888780; }\n\n  .empty-state { text-align: center; padding: 16px; color: #888780; font-size: 12px; font-weight: 500; background: rgba(5,4,46,0.03); border-radius: 8px; margin-top: 8px; }\n\n  .tile-grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin: 12px 0; }\n  .tile { border-radius: 8px; padding: 12px 14px; text-align: center; }\n  .tile-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px; }\n  .tile-value { font-size: 24px; font-weight: 700; }\n  .tile-sub { font-size: 10px; font-weight: 600; margin-top: 4px; }\n\n  .tile-total { background: rgba(5,4,46,0.04); }\n  .tile-total .tile-label, .tile-total .tile-value { color: #05042E; }\n  .tile-salvage { background: #E1F5EE; }\n  .tile-salvage .tile-label, .tile-salvage .tile-value, .tile-salvage .tile-sub { color: #085041; }\n  .tile-disposal { background: #fee2e2; }\n  .tile-disposal .tile-label, .tile-disposal .tile-value, .tile-disposal .tile-sub { color: #b91c1c; }\n  .tile-removed { background: #E3EFF6; }\n  .tile-removed .tile-label, .tile-removed .tile-value, .tile-removed .tile-sub { color: #1B4F6C; }\n\n  .alert-box { padding: 10px 14px; border-radius: 7px; font-size: 11px; font-weight: 600; margin-bottom: 8px; display: flex; align-items: center; gap: 8px; }\n  .alert-overdue { background: #fee2e2; border: 0.5px solid #fca5a5; color: #b91c1c; }\n  .alert-due-soon { background: #FAEEDA; border: 0.5px solid #f5deb0; color: #633806; }\n\n  .installed-box { margin-top: 14px; background: rgba(163,232,81,0.08); border: 0.5px solid rgba(163,232,81,0.3); border-radius: 10px; padding: 12px 16px; }\n  .installed-title { font-size: 11px; font-weight: 700; color: #085041; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 8px; }\n  .installed-row { display: flex; justify-content: space-between; align-items: center; padding: 5px 0; border-bottom: 0.5px solid rgba(163,232,81,0.25); }\n  .installed-row:last-of-type { border-bottom: none; }\n  .installed-part { font-size: 13px; font-weight: 600; color: #085041; }\n  .installed-serial { font-size: 11px; color: #5a8a1a; margin-left: 8px; }\n  .installed-cost { font-size: 13px; font-weight: 700; color: #085041; }\n  .installed-total-row { display: flex; justify-content: space-between; margin-top: 8px; padding-top: 8px; border-top: 2px solid rgba(163,232,81,0.4); }\n  .installed-total-label { font-size: 13px; font-weight: 700; color: #085041; }\n  .installed-total-value { font-size: 14px; font-weight: 800; color: #085041; }\n\n  .view-all-btn {\n    width: 100%; margin-top: 14px; height: 42px;\n    background: #05042E; color: #fff; border: none; border-radius: 8px;\n    font-family: 'Figtree', sans-serif; font-size: 13px; font-weight: 700;\n    cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;\n    transition: background 0.15s;\n  }\n  .view-all-btn:hover { background: #469BC0; }\n</style>\n\n<div class=\"app\" id=\"root\"></div>\n\n<script>\n  function fmtDate(d) {\n    if (!d) return '—';\n    const dt = new Date(d);\n    if (isNaN(dt.getTime())) return String(d);\n    return dt.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });\n  }\n\n  function escHtml(str) {\n    if (str === null || str === undefined) return '';\n    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');\n  }\n\n  function render(model) {\n    const m = model || {};\n    const total = m.total || 0;\n    const salvageable = m.salvageable || 0;\n    const scrapped = m.scrapped || 0;\n    const removed = m.removed || 0;\n    const overdue = m.overdue || 0;\n    const dueSoon = m.due_soon || 0;\n    const assessedAt = m.assessed_at || '';\n    const assessedBy = m.assessed_by || '';\n    const hasAssessment = total > 0;\n    const installedParts = m.installedParts || [];\n    const totalCost = installedParts.reduce(function(sum, p) { return sum + (parseFloat(p.part_cost) || 0); }, 0);\n    const partsCount = m.partsCount || 0;\n\n    let html = '<div class=\"header-row\">' +\n      '<div class=\"header-left\"><span class=\"header-icon\">📋</span><span class=\"header-title\">Pre-Inventory Assessment</span></div>' +\n      (hasAssessment && assessedAt ? '<div class=\"assessed-note\">Assessed ' + fmtDate(assessedAt) + ' by ' + escHtml(assessedBy) + '</div>' : '') +\n      '</div>';\n\n    if (!hasAssessment) {\n      html += '<div class=\"empty-state\">No pre-inventory assessment recorded for this asset.</div>';\n    } else {\n      html += '<div class=\"tile-grid-4\">' +\n        '<div class=\"tile tile-total\"><div class=\"tile-label\">Total Parts</div><div class=\"tile-value\">' + total + '</div></div>' +\n        '<div class=\"tile tile-salvage\"><div class=\"tile-label\">✓ Salvageable</div><div class=\"tile-value\">' + salvageable + '</div><div class=\"tile-sub\">' + (total > 0 ? Math.round(salvageable/total*100) : 0) + '% of total</div></div>' +\n        '<div class=\"tile tile-disposal\"><div class=\"tile-label\">✕ For Disposal</div><div class=\"tile-value\">' + scrapped + '</div><div class=\"tile-sub\">' + (total > 0 ? Math.round(scrapped/total*100) : 0) + '% of total</div></div>' +\n        '<div class=\"tile tile-removed\"><div class=\"tile-label\">↓ Removed</div><div class=\"tile-value\">' + removed + '</div><div class=\"tile-sub\">of ' + salvageable + ' salvageable</div></div>' +\n        '</div>';\n\n      if (overdue > 0) {\n        html += '<div class=\"alert-box alert-overdue\">⚠️ ' + overdue + ' part(s) have passed their 12-month R2V3 disposal deadline — immediate action required.</div>';\n      }\n      if (dueSoon > 0) {\n        html += '<div class=\"alert-box alert-due-soon\">⏱ ' + dueSoon + ' part(s) disposal deadline within 30 days.</div>';\n      }\n    }\n\n    if (installedParts.length > 0) {\n      html += '<div class=\"installed-box\"><div class=\"installed-title\">🔧 Parts Added to This Asset</div>';\n      installedParts.forEach(function(p) {\n        html += '<div class=\"installed-row\">' +\n          '<div><span class=\"installed-part\">' + escHtml(p.part_type || '—') + '</span>' +\n          (p.serial_number ? '<span class=\"installed-serial\">S/N: ' + escHtml(p.serial_number) + '</span>' : '') +\n          '</div>' +\n          '<span class=\"installed-cost\">' + (p.part_cost ? '£' + parseFloat(p.part_cost).toFixed(2) : '—') + '</span>' +\n          '</div>';\n      });\n      html += '<div class=\"installed-total-row\"><span class=\"installed-total-label\">Total Parts Cost</span><span class=\"installed-total-value\">£' + totalCost.toFixed(2) + '</span></div>';\n      html += '</div>';\n    }\n\n    html += '<button class=\"view-all-btn\" id=\"btn_view_all\">📦 View All Parts (' + partsCount + ')</button>';\n\n    document.getElementById('root').innerHTML = html;\n\n    const viewAllBtn = document.getElementById('btn_view_all');\n    if (viewAllBtn) {\n      viewAllBtn.addEventListener('click', function() {\n        appsmith.triggerEvent('onViewAllParts');\n      });\n    }\n  }\n\n  function initWhenReady() {\n    if (typeof appsmith === 'undefined' || !appsmith.onReady) {\n      setTimeout(initWhenReady, 50);\n      return;\n    }\n    appsmith.onReady(() => render(appsmith.model));\n    appsmith.onModelChange(() => render(appsmith.model));\n  }\n\n  initWhenReady();\n</script>",
    "js": ""
  },
