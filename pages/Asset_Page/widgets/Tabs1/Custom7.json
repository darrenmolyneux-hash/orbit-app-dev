    "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<style>\n  * { box-sizing: border-box; margin: 0; padding: 0; }\n  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 13px; background: transparent; padding: 12px; }\n  .summary { background: #fff; border: 1px solid #e2e8f0; border-radius: 10px; padding: 14px 18px; }\n  .header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; padding-bottom: 10px; border-bottom: 1px solid #f1f5f9; }\n  .title { font-size: 13px; font-weight: 600; color: #1A5C3A; display: flex; align-items: center; gap: 6px; }\n  .meta { font-size: 11px; color: #94a3b8; }\n  .stats { display: flex; gap: 12px; flex-wrap: wrap; }\n  .stat { display: flex; align-items: center; gap: 8px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 7px; padding: 8px 14px; min-width: 120px; }\n  .stat-icon { width: 28px; height: 28px; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0; }\n  .stat-info { display: flex; flex-direction: column; }\n  .stat-value { font-size: 18px; font-weight: 700; line-height: 1; }\n  .stat-label { font-size: 10px; color: #64748b; margin-top: 2px; text-transform: uppercase; letter-spacing: 0.04em; }\n  .stat.total .stat-icon { background: #f1f5f9; }\n  .stat.total .stat-value { color: #1e293b; }\n  .stat.salvageable .stat-icon { background: #E1F5EE; }\n  .stat.salvageable .stat-value { color: #1A5C3A; }\n  .stat.scrapped .stat-icon { background: #fee2e2; }\n  .stat.scrapped .stat-value { color: #b91c1c; }\n  .stat.overdue .stat-icon { background: #fee2e2; }\n  .stat.overdue .stat-value { color: #b91c1c; }\n  .stat.due_soon .stat-icon { background: #fffbeb; }\n  .stat.due_soon .stat-value { color: #92400e; }\n  .warning { display: flex; align-items: center; gap: 8px; margin-top: 10px; padding: 8px 12px; border-radius: 7px; font-size: 11px; font-weight: 500; }\n  .warning.red { background: #fee2e2; color: #b91c1c; border: 1px solid #fca5a5; }\n  .warning.amber { background: #fffbeb; color: #92400e; border: 1px solid #fbbf24; }\n  .no-assessment { text-align: center; padding: 20px; color: #94a3b8; font-size: 12px; }\n</style>\n</head>\n<body>\n<div class=\"summary\" id=\"summary\">\n  <div class=\"no-assessment\" id=\"noAssessment\">No pre-inventory assessment recorded for this asset.</div>\n  <div id=\"assessmentData\" style=\"display:none;\">\n    <div class=\"header\">\n      <div class=\"title\">\n        <svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#1A5C3A\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n          <path d=\"M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2\"/>\n          <rect x=\"9\" y=\"3\" width=\"6\" height=\"4\" rx=\"2\"/>\n          <path d=\"m9 12 2 2 4-4\"/>\n        </svg>\n        Pre-Inventory Assessment\n      </div>\n      <div class=\"meta\" id=\"metaText\"></div>\n    </div>\n    <div class=\"stats\">\n      <div class=\"stat total\">\n        <div class=\"stat-icon\">📦</div>\n        <div class=\"stat-info\">\n          <div class=\"stat-value\" id=\"valTotal\">0</div>\n          <div class=\"stat-label\">Total Parts</div>\n        </div>\n      </div>\n      <div class=\"stat salvageable\">\n        <div class=\"stat-icon\">✓</div>\n        <div class=\"stat-info\">\n          <div class=\"stat-value\" id=\"valSalvageable\">0</div>\n          <div class=\"stat-label\">Salvageable</div>\n        </div>\n      </div>\n      <div class=\"stat scrapped\">\n        <div class=\"stat-icon\">✕</div>\n        <div class=\"stat-info\">\n          <div class=\"stat-value\" id=\"valScrapped\">0</div>\n          <div class=\"stat-label\">For Disposal</div>\n        </div>\n      </div>\n      <div class=\"stat overdue\" id=\"statOverdue\" style=\"display:none;\">\n        <div class=\"stat-icon\">⚠️</div>\n        <div class=\"stat-info\">\n          <div class=\"stat-value\" id=\"valOverdue\">0</div>\n          <div class=\"stat-label\">Overdue</div>\n        </div>\n      </div>\n      <div class=\"stat due_soon\" id=\"statDueSoon\" style=\"display:none;\">\n        <div class=\"stat-icon\">⏱</div>\n        <div class=\"stat-info\">\n          <div class=\"stat-value\" id=\"valDueSoon\">0</div>\n          <div class=\"stat-label\">Due Soon</div>\n        </div>\n      </div>\n    </div>\n    <div id=\"warningOverdue\" class=\"warning red\" style=\"display:none;\">\n      ⚠️ <span id=\"warnOverdueText\"></span> part(s) have passed their 12-month R2V3 disposal deadline and require immediate action.\n    </div>\n    <div id=\"warningDueSoon\" class=\"warning amber\" style=\"display:none;\">\n      ⏱ <span id=\"warnDueSoonText\"></span> part(s) disposal deadline falls within the next 30 days.\n    </div>\n  </div>\n</div>\n\n<script>\n  function formatDate(dateStr) {\n    if (!dateStr) return '';\n    var d = new Date(dateStr);\n    var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];\n    return d.getDate() + ' ' + months[d.getMonth()] + ' ' + d.getFullYear();\n  }\n\n  function render(model) {\n    var total = model.total || 0;\n    if (total === 0) {\n      document.getElementById('noAssessment').style.display = 'block';\n      document.getElementById('assessmentData').style.display = 'none';\n      return;\n    }\n    document.getElementById('noAssessment').style.display = 'none';\n    document.getElementById('assessmentData').style.display = 'block';\n\n    document.getElementById('valTotal').textContent = total;\n    document.getElementById('valSalvageable').textContent = model.salvageable || 0;\n    document.getElementById('valScrapped').textContent = model.scrapped || 0;\n\n    if (model.assessed_at && model.assessed_by) {\n      document.getElementById('metaText').textContent = 'Assessed ' + formatDate(model.assessed_at) + ' by ' + model.assessed_by;\n    }\n\n    if (model.overdue > 0) {\n      document.getElementById('statOverdue').style.display = 'flex';\n      document.getElementById('valOverdue').textContent = model.overdue;\n      document.getElementById('warningOverdue').style.display = 'flex';\n      document.getElementById('warnOverdueText').textContent = model.overdue;\n    }\n\n    if (model.due_soon > 0) {\n      document.getElementById('statDueSoon').style.display = 'flex';\n      document.getElementById('valDueSoon').textContent = model.due_soon;\n      document.getElementById('warningDueSoon').style.display = 'flex';\n      document.getElementById('warnDueSoonText').textContent = model.due_soon;\n    }\n  }\n\n  appsmith.onReady(function() {\n    render(appsmith.model || {});\n  });\n\n  appsmith.onModelChange(function(model) {\n    render(model);\n  });\n</script>\n</body>\n</html>",
    "js": ""
  },
