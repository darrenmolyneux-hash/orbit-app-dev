dc2626; width: 14px; height: 14px; }\n\n  .component-toggles {\n    display: flex; gap: 24px; flex-wrap: wrap; background: rgba(70,155,192,0.06);\n    border-radius: 8px; padding: 12px 16px; margin-bottom: 14px; border: 0.5px solid rgba(70,155,192,0.2);\n  }\n  .toggles-header {\n    font-weight: 700; font-size: 11px; color: #888780; text-transform: uppercase;\n    letter-spacing: 0.06em; width: 100%; margin-bottom: 4px;\n  }\n  .toggle-label { display: flex; align-items: center; gap: 10px; cursor: pointer; user-select: none; }\n  .toggle-track {\n    width: 38px; height: 20px; border-radius: 20px; position: relative;\n    cursor: pointer; transition: 0.3s; flex-shrink: 0; background: #E0DFE1;\n  }\n  .toggle-track.on { background: #469BC0; }\n  .toggle-thumb {\n    position: absolute; top: 3px; left: 3px; width: 14px; height: 14px;\n    border-radius: 50%; background: #fff; transition: 0.3s;\n  }\n  .toggle-track.on .toggle-thumb { left: 21px; }\n  .toggle-text { font-size: 13px; font-weight: 600; color: #888780; }\n  .toggle-text.on { color: #05042E; }\n\n  .overall-row {\n    display: flex; align-items: center; gap: 16px; padding: 14px 16px;\n    border-radius: 8px; margin-top: 4px; background: rgba(5,4,46,0.04);\n    border: 0.5px solid rgba(0,0,0,0.08);\n  }\n  .overall-label { font-weight: 700; font-size: 14px; color: #05042E; }\n  .overall-badge {\n    display: inline-flex; align-items: center; justify-content: center;\n    width: 36px; height: 36px; border-radius: 8px; color: #fff;\n    font-weight: 700; font-size: 18px;\n  }\n  .overall-placeholder { color: #888780; font-size: 13px; }\n\n  .notes-box { margin-top: 14px; }\n  .notes-title { font-weight: 700; font-size: 13px; color: #05042E; margin-bottom: 6px; }\n  .notes-textarea {\n    width: 100%; padding: 10px; border-radius: 6px; border: 0.5px solid rgba(0,0,0,0.15);\n    font-family: 'Figtree', sans-serif; font-size: 13px; resize: vertical;\n    box-sizing: border-box; color: #05042E; outline: none; min-height: 60px;\n  }\n</style>\n\n<div id=\"root\" class=\"grading-wrap\"></div>\n\n<script>\n  const GRADE_RANK = { A: 0, B: 1, C: 2, F: 3 };\n  const GRADE_COLORS = { A: '#5a8a1a', B: '#469BC0', C: '#F59E0B', F: '#dc2626' };\n  const NAVY = '#05042E';\n  const BLUE = '#469BC0';\n\n  const LOCK_STATUS_MAP = {\n    'BIOS Lock': 9,\n    'MDM Lock': 8,\n    'iCloud Lock': 10\n  };\n\n  // ---- state (module-level, persists across renders) ----\n  let selections = {};\n  let locks = { 'BIOS Lock': false, 'MDM Lock': false, 'iCloud Lock': false };\n  let noHdd = false;\n  let noRam = false;\n  let notes = '';\n  let lastLoadedAt = null;\n\n  function buildCategories(rows) {\n    const categories = [];\n    const catMap = {};\n    rows.forEach(r => {\n      if (!catMap[r.category_id]) {\n        catMap[r.category_id] = { id: r.category_id, name: r.category_name, order: r.cat_order, isChecklist: r.is_checklist, options: [] };\n        categories.push(catMap[r.category_id]);\n      }\n      catMap[r.category_id].options.push({ id: r.option_id, label: r.option_label, grade: r.grade_value, order: r.opt_order });\n    });\n    categories.sort((a, b) => a.order - b.order);\n    categories.forEach(c => c.options.sort((a, b) => a.order - b.order));\n    return categories;\n  }\n\n  function buildInitSel(categories, existing) {\n    const s = {};\n    categories.forEach(c => {\n      if (c.isChecklist) return;\n      let id = null;\n      if (c.name === 'Cosmetics') id = existing.cosmetics_option_id;\n      if (c.name === 'LCD' || c.name === 'Screen') id = existing.lcd_option_id;\n      if (c.name === 'Functionality') id = existing.functionality_option_id;\n      if (c.name === 'Missing Components') id = existing.missing_option_id;\n      if (id) s[c.id] = id;\n    });\n    return s;\n  }\n\n  function computeOverallGrade(gradeCategories, sel) {\n    const allAnswered = gradeCategories.length > 0 && gradeCategories.every(c => sel[c.id]);\n    if (!allAnswered) return null;\n    return gradeCategories.reduce((worst, c) => {\n      const opt = c.options.find(o => o.id === sel[c.id]);\n      const g = opt ? opt.grade : 'A';\n      return GRADE_RANK[g] > GRADE_RANK[worst] ? g : worst;\n    }, 'A');\n  }\n\n  function pushModel(gradeCategories) {\n    const allAnswered = gradeCategories.length > 0 && gradeCategories.every(c => selections[c.id]);\n    const overallGrade = computeOverallGrade(gradeCategories, selections);\n    const lockActive = Object.values(locks).some(v => v);\n    return Promise.resolve(appsmith.updateModel({\n      selections, locks, noHdd, noRam,\n      notes, overallGrade, allAnswered,\n      anyLockActive: lockActive,\n      biosLock: locks['BIOS Lock'] || false,\n      mdmLock: locks['MDM Lock'] || false,\n      icloudLock: locks['iCloud Lock'] || false\n    }));\n  }\n\n  function pushModelAndSave(gradeCategories) {\n    pushModel(gradeCategories).then(function() {\n      appsmith.triggerEvent('onStoreLockState');\n      appsmith.triggerEvent('saveGrading');\n    });\n  }\n\n  function selectOption(gradeCategories, categoryId, optionId) {\n    selections = { ...selections, [categoryId]: optionId };\n    renderAll(gradeCategories);\n    pushModelAndSave(gradeCategories);\n  }\n\n  function toggleLock(gradeCategories, label) {\n    locks = { ...locks, [label]: !locks[label] };\n    renderAll(gradeCategories);\n    pushModelAndSave(gradeCategories);\n  }\n\n  function toggleNoHdd(gradeCategories) {\n    noHdd = !noHdd;\n    renderAll(gradeCategories);\n    pushModelAndSave(gradeCategories);\n  }\n\n  function toggleNoRam(gradeCategories) {\n    noRam = !noRam;\n    renderAll(gradeCategories);\n    pushModelAndSave(gradeCategories);\n  }\n\n  function clearLocks() {\n    appsmith.triggerEvent('onClearLocks');\n  }\n\n  function renderAll(gradeCategories) {\n    render(appsmith.model, gradeCategories);\n  }\n\n  function render(model, cachedGradeCategories) {\n    const m = model || {};\n    const rows = m.gradingData || [];\n    const existing = rows[0] || {};\n    const categories = buildCategories(rows);\n    const gradeCategories = cachedGradeCategories || categories.filter(c => !c.isChecklist);\n\n    // reinit state only when a fresh load happens\n    if (rows.length > 0 && m.loadedAt !== lastLoadedAt) {\n      lastLoadedAt = m.loadedAt;\n      selections = buildInitSel(categories, existing);\n      locks = {\n        'BIOS Lock': existing.bios_lock || false,\n        'MDM Lock': existing.mdm_lock || false,\n        'iCloud Lock': existing.icloud_lock || false\n      };\n      noHdd = m.noHdd !== undefined ? m.noHdd : (existing.no_hdd || false);\n      noRam = m.noRam !== undefined ? m.noRam : (existing.no_ram || false);\n      notes = existing.notes || '';\n    }\n\n    const overallGrade = computeOverallGrade(gradeCategories, selections);\n    const lockActive = Object.values(locks).some(v => v);\n    const activeLockNames = Object.keys(locks).filter(k => locks[k]);\n\n    let html = '';\n\n    if (lockActive) {\n      html += `\n        <div class=\"lock-banner\">\n          <div>\n            <div class=\"lock-title\">⚠ Device Locked — ${activeLockNames.join(', ')}</div>\n            <div class=\"lock-sub\">Only \"Stripped for Parts\" status is available until lock is cleared.</div>\n          </div>\n          <button class=\"lock-override-btn\" id=\"btn_clear_locks\">✓ Override — Release Lock</button>\n        </div>`;\n    }\n\n    gradeCategories.forEach(c => {\n      html += `<div class=\"cat-row\"><div class=\"cat-title\">${c.name}</div><div class=\"cat-options\">`;\n      c.options.forEach(o => {\n        const isSel = selections[c.id] === o.id;\n        const col = GRADE_COLORS[o.grade] || BLUE;\n        html += `<button class=\"opt-btn${isSel ? ' selected' : ''}\" data-cat=\"${c.id}\" data-opt=\"${o.id}\"\n          style=\"${isSel ? `border-color:${col};background:${col};color:#fff;` : ''}\">${o.label}</button>`;\n      });\n      html += `</div></div>`;\n    });\n\n    const lockCat = categories.find(c => c.isChecklist);\n    if (lockCat) {\n      html += `<div class=\"locks-section\"><div class=\"locks-title\">Locks</div><div class=\"locks-row\">`;\n      lockCat.options.forEach(o => {\n        if (!LOCK_STATUS_MAP[o.label]) return;\n        html += `<label class=\"lock-check-label\">\n          <input type=\"checkbox\" data-lock=\"${o.label}\" ${locks[o.label] ? 'checked' : ''}/>\n          ${o.label}\n        </label>`;\n      });\n      html += `</div></div>`;\n    }\n\n    html += `\n      <div class=\"component-toggles\">\n        <div class=\"toggles-header\">Missing Components</div>\n        <label class=\"toggle-label\" id=\"toggle_hdd\">\n          <div class=\"toggle-track${noHdd ? ' on' : ''}\"><div class=\"toggle-thumb\"></div></div>\n          <span class=\"toggle-text${noHdd ? ' on' : ''}\">No Hard Drive</span>\n        </label>\n        <label class=\"toggle-label\" id=\"toggle_ram\">\n          <div class=\"toggle-track${noRam ? ' on' : ''}\"><div class=\"toggle-thumb\"></div></div>\n          <span class=\"toggle-text${noRam ? ' on' : ''}\">No RAM</span>\n        </label>\n      </div>\n\n      <div class=\"overall-row\" style=\"background:${overallGrade ? GRADE_COLORS[overallGrade] + '12' : 'rgba(5,4,46,0.04)'};\n        border-color:${overallGrade ? GRADE_COLORS[overallGrade] : 'rgba(0,0,0,0.08)'}\">\n        <span class=\"overall-label\">Overall Cosmetic Grade:</span>\n        ${overallGrade\n          ? `<span class=\"overall-badge\" style=\"background:${GRADE_COLORS[overallGrade]}\">${overallGrade}</span>`\n          : `<span class=\"overall-placeholder\">Answer all categories to calculate</span>`}\n      </div>\n\n      <div class=\"notes-box\">\n        <div class=\"notes-title\">Grading Notes</div>\n        <textarea class=\"notes-textarea\" id=\"notes_input\" placeholder=\"Add any notes about cosmetic condition, defects, or accessories...\">${notes}</textarea>\n      </div>\n    `;\n\n    const root = document.getElementById('root');\n    root.innerHTML = html;\n\n    // wire events\n    const clearBtn = document.getElementById('btn_clear_locks');\n    if (clearBtn) clearBtn.addEventListener('click', clearLocks);\n\n    root.querySelectorAll('.opt-btn').forEach(btn => {\n      btn.addEventListener('click', () => {\n        selectOption(gradeCategories, Number(btn.dataset.cat), Number(btn.dataset.opt));\n      });\n    });\n\n    root.querySelectorAll('[data-lock]').forEach(cb => {\n      cb.addEventListener('change', () => toggleLock(gradeCategories, cb.dataset.lock));\n    });\n\n    const hddToggle = document.getElementById('toggle_hdd');\n    if (hddToggle) hddToggle.addEventListener('click', () => toggleNoHdd(gradeCategories));\n\n    const ramToggle = document.getElementById('toggle_ram');\n    if (ramToggle) ramToggle.addEventListener('click', () => toggleNoRam(gradeCategories));\n\n    const notesInput = document.getElementById('notes_input');\n    if (notesInput) {\n      notesInput.addEventListener('input', (e) => { notes = e.target.value; });\n      notesInput.addEventListener('blur', () => pushModelAndSave(gradeCategories));\n    }\n  }\n\n  function initWhenReady() {\n    if (typeof appsmith === 'undefined' || !appsmith.onReady) {\n      setTimeout(initWhenReady, 50);\n      return;\n    }\n    appsmith.onReady(() => render(appsmith.model));\n    appsmith.onModelChange(() => render(appsmith.model));\n  }\n\n  initWhenReady();\n</script>",
    "js": ""
  },
  "version": 1,
  "widgetId": "ojbrowqz2q",
  "widgetName": "Custom_Grading"
}