    "html": "<!-- Paste into Custom5's source editor. No DOCTYPE/html/head/body wrapper needed. -->\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Figtree:wght@400;600;700&display=swap');\n  * { box-sizing: border-box; font-family: 'Figtree', sans-serif; margin: 0; padding: 0; }\n\n  .app { padding: 4px; }\n\n  .lock-banner {\n    background: #fee2e2; border: 1px solid #fca5a5; border-radius: 8px;\n    padding: 10px 14px; margin-bottom: 14px; display: flex; align-items: center; gap: 10px;\n  }\n  .lock-icon { font-size: 16px; }\n  .lock-title { font-weight: 700; color: #b91c1c; font-size: 13px; }\n  .lock-sub { font-size: 11px; color: #b91c1c; margin-top: 2px; }\n\n  .header-row { display: flex; justify-content: space-between; align-items: flex-start; }\n  .identity { display: flex; gap: 12px; align-items: flex-start; }\n  .icon-box {\n    width: 40px; height: 40px; border-radius: 8px; background: rgba(5,4,46,0.1);\n    display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0;\n  }\n  .label-sm { font-size: 10px; font-weight: 700; text-transform: uppercase; color: #888780; letter-spacing: 0.05em; margin-bottom: 2px; }\n  .title-lg { font-size: 18px; font-weight: 700; color: #05042E; }\n  .serial-sm { font-size: 11px; color: #888780; margin-top: 2px; }\n  .text-right { text-align: right; }\n  .value-md { font-size: 13px; font-weight: 600; color: #05042E; }\n\n  .dial-row { display: flex; gap: 8px; align-items: center; margin-top: 10px; }\n  .dial-label { font-size: 10px; font-weight: 700; text-transform: uppercase; color: #888780; letter-spacing: 0.05em; }\n  .dial-value { font-size: 13px; font-weight: 600; color: #05042E; }\n\n  .divider { height: 0.5px; background: rgba(0,0,0,0.08); margin: 14px 0; }\n\n  .tile-grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; }\n  .tile { border-radius: 10px; padding: 12px 14px; }\n  .tile-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px; }\n  .tile-value-lg { font-size: 18px; font-weight: 700; display: block; }\n  .tile-value-md { font-size: 14px; font-weight: 700; }\n  .tile-sub { font-size: 10px; margin-top: 3px; }\n  .status-badge { display: inline-block; font-size: 12px; font-weight: 700; padding: 3px 10px; border-radius: 20px; }\n\n  .grade-tile { display: flex; justify-content: space-between; align-items: center; }\n  .grade-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }\n  .grade-sub { font-size: 10px; margin-top: 2px; }\n  .grade-circle {\n    width: 36px; height: 36px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0;\n  }\n  .grade-text { font-size: 16px; font-weight: 700; }\n\n  .status-row { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }\n  .status-label { font-size: 10px; font-weight: 700; text-transform: uppercase; color: #888780; letter-spacing: 0.05em; }\n  .status-select-inline {\n    font-family: 'Figtree', sans-serif; font-size: 13px; font-weight: 600; color: #05042E;\n    border: 0.5px solid rgba(0,0,0,0.15); border-radius: 6px; padding: 6px 10px; background: #fff; outline: none;\n  }\n  .lock-hint { font-size: 11px; color: #b91c1c; font-weight: 600; }\n</style>\n\n<div id=\"root\" class=\"app\"></div>\n\n<script>\n  const NAVY = '#05042E';\n  const BLUE = '#469BC0';\n\n  const STATUS_COLOURS = {\n    intake:      { background: 'rgba(70,155,192,0.12)', color: BLUE },\n    data:        { background: 'rgba(163,232,81,0.12)', color: '#5a8a1a' },\n    compliance:  { background: '#fef3c7', color: '#92400e' },\n    evaluation:  { background: 'rgba(5,4,46,0.06)', color: NAVY },\n    sales:       { background: 'rgba(163,232,81,0.15)', color: '#5a8a1a' },\n    end_of_life: { background: '#fee2e2', color: '#b91c1c' },\n  };\n\n  const LOCK_STATUS_IDS = [8, 9, 10];\n  const STRIPPED_STATUS_ID = 15;\n\n  function fmtDate(d) {\n    if (!d) return '—';\n    const dt = new Date(d);\n    if (isNaN(dt.getTime())) return String(d);\n    return dt.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });\n  }\n\n  function getCategoryStyle(category) {\n    return STATUS_COLOURS[category] || { background: 'rgba(5,4,46,0.06)', color: NAVY };\n  }\n\n  function styleAttr(obj) {\n    return Object.entries(obj).map(([k, v]) => {\n      const cssKey = k.replace(/[A-Z]/g, m => '-' + m.toLowerCase());\n      return `${cssKey}:${v}`;\n    }).join(';');\n  }\n\n  function handleStatusChange(e) {\n    const newStatusId = parseInt(e.target.value, 10);\n    appsmith.updateModel({ selectedStatusId: newStatusId });\n    appsmith.triggerEvent('statusChange');\n  }\n\n  function render(model) {\n    const data = model || {};\n    const row = data.asset || {};\n    const statusTypes = data.statusTypes || [];\n    const drives = data.drives || [];\n    const shredRecords = data.shredRecords || [];\n    const shreddedSerials = new Set(shredRecords.map(r => r.drive_serial));\n\n    const itemType = row.item_type_name || '—';\n    const makeModel = (row.make_name || '—') + ' · ' + (row.model_name || '—');\n    const serial = 'Serial ' + (row.serial_number || '—');\n    const dateAdded = fmtDate(row.date_added);\n    const addedBy = 'by ' + (row.added_by || '—');\n    const erasure = row.erasure_status || '—';\n\n    const isMultiDrive = drives.length > 1;\n    let erasureDisplay = erasure;\n    let erasureSubText = 'via Blancco';\n    let erasureHasFailures = false;\n\n    if (isMultiDrive) {\n      const passed = drives.filter(d => /success|erased/i.test(d.erasure_status || '')).length;\n      const shredded = drives.filter(d => !/success|erased/i.test(d.erasure_status || '') && shreddedSerials.has(d.serial)).length;\n      const failed = drives.length - passed - shredded;\n\n      erasureHasFailures = failed > 0;\n      const parts = [`${passed} Pass`];\n      if (shredded > 0) parts.push(`${shredded} Shredded`);\n      if (failed > 0) parts.push(`${failed} Fail`);\n      erasureDisplay = parts.join(' / ');\n      erasureSubText = failed > 0\n        ? `${failed} drive${failed > 1 ? 's' : ''} need attention`\n        : 'All drives accounted for — via Blancco';\n    }\n\n    const erasureStyle = isMultiDrive\n      ? (erasureHasFailures\n          ? { background: '#fee2e2', color: '#b91c1c' }\n          : { background: 'rgba(163,232,81,0.12)', color: '#5a8a1a' })\n      : erasure.toLowerCase().includes('success')\n      ? { background: 'rgba(163,232,81,0.12)', color: '#5a8a1a' }\n      : erasure.toLowerCase().includes('fail') || erasure.toLowerCase().includes('error')\n      ? { background: '#fee2e2', color: '#b91c1c' }\n      : { background: 'rgba(5,4,46,0.06)', color: '#888780' };\n\n    const dataBearing = !!row.data_bearing;\n    const dbValue = dataBearing ? 'Yes' : 'No';\n    const erasureDone = isMultiDrive\n      ? !erasureHasFailures && drives.length > 0\n      : !!row.erasure_status && erasure.toLowerCase().includes('success');\n\n    const dbStyle = dataBearing && !erasureDone\n      ? { background: '#fee2e2', color: '#b91c1c' }\n      : { background: 'rgba(163,232,81,0.12)', color: '#5a8a1a' };\n\n    const overallGrade = row.overall_grade;\n    const gradeText = overallGrade || '—';\n    const gradeSub = overallGrade ? 'Grading complete' : 'Pending';\n    const gradeOpacity = overallGrade ? 1 : 0.3;\n\n    const gradeColor = overallGrade\n      ? (overallGrade === 'A' ? '#5a8a1a'\n        : overallGrade === 'B' ? '#469BC0'\n        : overallGrade === 'C' ? '#F59E0B'\n        : overallGrade === 'F' ? '#dc2626'\n        : NAVY)\n      : NAVY;\n\n    const gradeTileBg = overallGrade ? gradeColor + '18' : 'rgba(5,4,46,0.04)';\n    const erasureRequired = dataBearing && !erasureDone;\n    const currentStatusId = row.status_id;\n    const currentStatus = statusTypes.find(s => s.status_id === currentStatusId);\n\n    const isLocked = LOCK_STATUS_IDS.includes(currentStatusId);\n    const lockName = isLocked ? (currentStatus?.status_name || 'Device Locked') : null;\n    const catStyle = getCategoryStyle(currentStatus?.category);\n\n    const root = document.getElementById('root');\n\n    let html = '';\n\n    if (isLocked) {\n      html += `\n        <div class=\"lock-banner\">\n          <span class=\"lock-icon\">🔒</span>\n          <div>\n            <div class=\"lock-title\">${lockName} Active</div>\n            <div class=\"lock-sub\">Asset is locked. Only \"Stripped for Parts\" is available. Clear lock in Grading tab to release.</div>\n          </div>\n        </div>`;\n    }\n\n    html += `\n      <div class=\"header-row\">\n        <div class=\"identity\">\n          <div class=\"icon-box\">💻</div>\n          <div>\n            <p class=\"label-sm\">${itemType}</p>\n            <p class=\"title-lg\">${makeModel}</p>\n            <p class=\"serial-sm\">${serial}</p>\n          </div>\n        </div>\n        <div class=\"text-right\">\n          <p class=\"label-sm\">Date added</p>\n          <p class=\"value-md\">${dateAdded}</p>\n          <p class=\"serial-sm\">${addedBy}</p>\n        </div>\n      </div>\n\n      <div class=\"dial-row\">\n        <span class=\"dial-label\">Dial ref</span>\n        <span class=\"dial-value\">—</span>\n      </div>\n\n      <div class=\"divider\"></div>\n\n      <div class=\"tile-grid-4\">\n        <div class=\"tile\" style=\"background: rgba(5,4,46,0.04)\">\n          <p class=\"tile-label\" style=\"color:#888780\">Status</p>\n          <span class=\"status-badge\" style=\"${styleAttr(catStyle)}\">${currentStatus?.status_name || '—'}</span>\n          ${erasureRequired ? `<p class=\"tile-sub\" style=\"color:#888780\">Erasure required before sale/disposal</p>` : ''}\n        </div>\n\n        <div class=\"tile\" style=\"${styleAttr(dbStyle)}\">\n          <p class=\"tile-label\" style=\"color:${dbStyle.color}\">Data bearing</p>\n          <span class=\"tile-value-lg\" style=\"color:${dbStyle.color}\">${dbValue}</span>\n          ${dataBearing && erasureDone ? `<p class=\"tile-sub\" style=\"color:${dbStyle.color}\">Erasure confirmed</p>` : ''}\n          ${dataBearing && !erasureDone ? `<p class=\"tile-sub\" style=\"color:${dbStyle.color}\">Awaiting erasure</p>` : ''}\n        </div>\n\n        <div class=\"tile\" style=\"${styleAttr(erasureStyle)}\">\n          <p class=\"tile-label\" style=\"color:${erasureStyle.color}\">Erasure state</p>\n          <div class=\"tile-value-md\" style=\"color:${erasureStyle.color}\">${erasureDisplay}</div>\n          <p class=\"tile-sub\" style=\"color:${erasureStyle.color}\">${erasureSubText}</p>\n        </div>\n\n        <div class=\"tile grade-tile\" style=\"background:${gradeTileBg}\">\n          <div>\n            <p class=\"grade-label\" style=\"color:${gradeColor}\">Grade</p>\n            <p class=\"grade-sub\" style=\"color:${gradeColor}\">${gradeSub}</p>\n          </div>\n          <div class=\"grade-circle\" style=\"border:3px solid ${gradeColor}\">\n            <span class=\"grade-text\" style=\"opacity:${gradeOpacity};color:${gradeColor}\">${gradeText}</span>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"divider\"></div>\n\n      <div class=\"status-row\">\n        <span class=\"status-label\">Update status</span>\n        <select class=\"status-select-inline\" id=\"status_select\">\n          ${statusTypes.map(s => {\n            const blocked = isLocked && s.status_id !== STRIPPED_STATUS_ID;\n            const selected = s.status_id === currentStatusId ? 'selected' : '';\n            return `<option value=\"${s.status_id}\" ${blocked ? 'disabled' : ''} ${selected}>${s.status_name}${blocked ? ' (locked)' : ''}</option>`;\n          }).join('')}\n        </select>\n        ${isLocked ? `<span class=\"lock-hint\">🔒 Clear lock in Grading tab to enable all statuses</span>` : ''}\n      </div>\n    `;\n\n    root.innerHTML = html;\n\n    const select = document.getElementById('status_select');\n    if (select) select.addEventListener('change', handleStatusChange);\n  }\n\n  function initWhenReady() {\n    if (typeof appsmith === 'undefined' || !appsmith.onReady) {\n      setTimeout(initWhenReady, 50);\n      return;\n    }\n    appsmith.onReady(() => render(appsmith.model));\n    appsmith.onModelChange(() => render(appsmith.model));\n  }\n\n  initWhenReady();\n</script>",
    "js": ""
  },
