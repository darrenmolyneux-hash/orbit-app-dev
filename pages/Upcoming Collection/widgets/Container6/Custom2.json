 td.td-goto { text-align: center; }\n\n  .id-cell { font-size: 11px; font-weight: 700; color: #888780; white-space: nowrap; }\n\n  .badge {\n    display: inline-block;\n    padding: 3px 10px;\n    border-radius: 20px;\n    font-size: 10px;\n    font-weight: 700;\n    text-transform: uppercase;\n    letter-spacing: 0.03em;\n  }\n\n  .b-booked, .b-booking-in        { background: #E3EFF6; color: #1B4F6C; }\n  .b-booked-in, .b-collected      { background: #FAEEDA; color: #633806; }\n  .b-received                      { background: #FAEEDA; color: #633806; }\n  .b-processing                    { background: #ede9fe; color: #6d28d9; }\n  .b-complete, .b-booking-complete { background: #E1F5EE; color: #085041; }\n  .b-default                       { background: rgba(5,4,46,0.06); color: #888780; }\n\n  .asset-count { text-align: center; font-size: 12px; font-weight: 700; }\n  .asset-count.has-assets { color: #085041; }\n  .asset-count.no-assets  { color: #888780; }\n\n  .goto-btn {\n    background: rgba(5,4,46,0.1);\n    border: none;\n    border-radius: 8px;\n    width: 28px;\n    height: 28px;\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    color: #05042E;\n    transition: background 0.15s, color 0.15s;\n  }\n\n  .goto-btn:hover { background: #A3E851; color: #05042E; }\n  .goto-btn svg { pointer-events: none; }\n\n  .no-results {\n    padding: 2.5rem;\n    text-align: center;\n    color: #888780;\n    font-size: 13px;\n    font-weight: 500;\n  }\n</style>\n\n<div class=\"widget-wrap\">\n  <div class=\"toolbar\">\n    <div class=\"search-row\">\n      <svg width=\"15\" height=\"15\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#888780\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n        <circle cx=\"11\" cy=\"11\" r=\"8\"/><line x1=\"21\" y1=\"21\" x2=\"16.65\" y2=\"16.65\"/>\n      </svg>\n      <input type=\"text\" id=\"searchInput\" placeholder=\"Search collections...\" oninput=\"applyFilters()\" />\n    </div>\n    <div class=\"filter-pills\" id=\"filterPills\"></div>\n  </div>\n  <div class=\"table-scroll\">\n    <table>\n      <colgroup>\n        <col class=\"col-id\" />\n        <col class=\"col-customer\" />\n        <col class=\"col-address\" />\n        <col class=\"col-date\" />\n        <col class=\"col-status\" />\n        <col class=\"col-assets\" />\n        <col class=\"col-goto\" />\n      </colgroup>\n      <thead>\n        <tr>\n          <th>ID</th>\n          <th>Customer</th>\n          <th>Address</th>\n          <th>Collection Date</th>\n          <th>Status</th>\n          <th class=\"th-assets\">Assets</th>\n          <th class=\"th-goto\">Go to</th>\n        </tr>\n      </thead>\n      <tbody id=\"tableBody\"></tbody>\n    </table>\n    <div id=\"noResults\" class=\"no-results\" style=\"display:none;\">No collections found</div>\n  </div>\n</div>\n\n<script>\n  const STATUS_CONFIG = {\n    'Booked':             { pillKey: 'booked',           badgeClass: 'b-booked' },\n    'Booking In':         { pillKey: 'booking-in',       badgeClass: 'b-booking-in' },\n    'Booked In':          { pillKey: 'booked-in',        badgeClass: 'b-booked-in' },\n    'Collected':          { pillKey: 'collected',        badgeClass: 'b-collected' },\n    'Received':           { pillKey: 'received',         badgeClass: 'b-received' },\n    'Processing/Pricing': { pillKey: 'processing',       badgeClass: 'b-processing' },\n    'Complete':           { pillKey: 'complete',         badgeClass: 'b-complete' },\n    'Booking complete':   { pillKey: 'booking-complete', badgeClass: 'b-booking-complete' },\n    'All Assets Booked':  { pillKey: 'complete',         badgeClass: 'b-complete' },\n  };\n\n  const STATUS_ORDER = Object.keys(STATUS_CONFIG);\n  let allData = [];\n  let activeStatus = 'All';\n\n  function initData() {\n    const model = appsmith.model || {};\n    allData = Array.isArray(model.collections) ? model.collections : [];\n    applyFilters();\n  }\n\n  function buildPills() {\n    const container = document.getElementById('filterPills');\n    const presentStatuses = STATUS_ORDER.filter(s => allData.some(r => r.status === s));\n    let html = '<span class=\"pill ' + (activeStatus==='All' ? 'active-all' : '') + '\" onclick=\"setFilter(\\'All\\')\">All <span class=\"cnt\">' + allData.length + '</span></span>';\n    presentStatuses.forEach(function(s) {\n      const cfg = STATUS_CONFIG[s];\n      const count = allData.filter(r => r.status === s).length;\n      const isActive = activeStatus === s ? 'active-' + cfg.pillKey : '';\n      html += '<span class=\"pill ' + isActive + '\" onclick=\"setFilter(\\'' + s.replace(/'/g,\"\\\\'\") + '\\')\">' + s + ' <span class=\"cnt\">' + count + '</span></span>';\n    });\n    container.innerHTML = html;\n  }\n\n  function renderTable(data) {\n    const tbody = document.getElementById('tableBody');\n    const noResults = document.getElementById('noResults');\n    if (!data.length) {\n      tbody.innerHTML = '';\n      noResults.style.display = 'block';\n      return;\n    }\n    noResults.style.display = 'none';\n    tbody.innerHTML = data.map(function(row) {\n      const customer   = row.customer_name || '';\n      const address    = row.address1 || '';\n      const date = row.collection_date ? new Date(row.collection_date).toLocaleDateString('en-GB', {day:'2-digit',month:'2-digit',year:'numeric'}) : '';\n      const status     = row.status || '';\n      const id         = row.collection_id || row.id || '';\n      const assetCount = row.asset_count || 0;\n      const badgeClass = (STATUS_CONFIG[status] || { badgeClass: 'b-default' }).badgeClass;\n      const assetCountClass = assetCount > 0 ? 'has-assets' : 'no-assets';\n      return '<tr class=\"data-row\">' +\n        '<td class=\"id-cell\">' + escHtml(String(id)) + '</td>' +\n        '<td title=\"' + escHtml(customer) + '\">' + escHtml(customer) + '</td>' +\n        '<td title=\"' + escHtml(address) + '\">' + escHtml(address) + '</td>' +\n        '<td>' + escHtml(date) + '</td>' +\n        '<td><span class=\"badge ' + badgeClass + '\">' + escHtml(status) + '</span></td>' +\n        '<td class=\"asset-count ' + assetCountClass + '\">' + assetCount + '</td>' +\n        '<td class=\"td-goto\"><button class=\"goto-btn\" onclick=\"goToCollection(' + JSON.stringify(id) + ')\" aria-label=\"Go to collection\">' +\n        '<svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\">' +\n        '<line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/><polyline points=\"12 5 19 12 12 19\"/></svg>' +\n        '</button></td></tr>';\n    }).join('');\n  }\n\n  function escHtml(str) {\n    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');\n  }\n\n  window.setFilter = function(status) {\n    activeStatus = status;\n    window.applyFilters();\n  };\n\n  window.applyFilters = function() {\n    const q = (document.getElementById('searchInput').value || '').toLowerCase();\n    let filtered = allData;\n    if (activeStatus !== 'All') filtered = filtered.filter(r => r.status === activeStatus);\n    if (q) {\n      filtered = filtered.filter(r =>\n        (r.customer_name || '').toLowerCase().includes(q) ||\n        (r.address1 || '').toLowerCase().includes(q) ||\n        (r.collection_date || '').toLowerCase().includes(q) ||\n        (r.status || '').toLowerCase().includes(q)\n      );\n    }\n    buildPills();\n    renderTable(filtered);\n  };\n\n  window.goToCollection = function(id) {\n    appsmith.updateModel({ collectionId: id });\n    setTimeout(function() {\n      appsmith.triggerEvent('onGoTo');\n    }, 100);\n  };\n\n  function initWhenReady() {\n    if (typeof appsmith === 'undefined' || !appsmith.onReady) {\n      setTimeout(initWhenReady, 50);\n      return;\n    }\n    appsmith.onReady(function() {\n      initData();\n      appsmith.onModelChange(initData);\n    });\n  }\n\n  initWhenReady();\n</script>",
    "js": ""
  },
