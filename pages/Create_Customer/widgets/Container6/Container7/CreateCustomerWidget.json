    "css": ".app {\n  height: calc(var(--appsmith-ui-height) * 1px);\n  width: calc(var(--appsmith-ui-width) * 1px);\n  justify-content: center;\n  border-radius: var(--appsmith-theme-borderRadius);\n  box-shadow: var(--appsmith-theme-boxShadow);\n  padding: 29px 25px;\n  box-sizing: border-box;\n  font-family: system-ui;\n  background: #fff;\n}\n\n.tip-container {\n  margin-bottom: 20px;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.tip-container h2 {\n  margin-bottom: 20px;\n  font-size: 16px;\n  font-weight: 700;\n}\n\n.tip-header {\n  display: flex;\n  justify-content: space-between;\n  align-items: baseline;\n  margin-bottom: 9px;\n}\n\n.tip-header div {\n  color: #999;\n}\n\n.content {\n  white-space: pre-wrap;\n  word-break: break-word;\n  font-size: 14px;\n  line-height: 1.571429;\n}\n\n.button-container {\n  text-align: right;\n  padding-top: 4px;\n}\n\n.button-container button {\n  margin: 0 10px;\n  cursor: pointer;\n  border-radius: var(--appsmith-theme-borderRadius);\n  padding: 6px 16px;\n  background: none;\n  height: auto;\n  transition: all 0.3s ease;\n}\n\n.button-container button.primary {\n  background: var(--appsmith-theme-primaryColor) !important;\n  color: #fff;\n  border: 1px solid var(--appsmith-theme-primaryColor) !important;\n}\n\n.button-container button.reset {\n  border: 1px solid #999;\n  color: #999;\n  outline: none;\n  box-shadow: none;\n}\n\n.button-container button.reset:hover:not(:disabled) {\n  color: var(--appsmith-theme-primaryColor);\n  border-color: var(--appsmith-theme-primaryColor);\n}\n\n.button-container button.reset:disabled {\n  cursor: default;\n}",
    "html": "<!DOCTYPE html>\n<html>\n<head>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Figtree:wght@400;600;700&display=swap');\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n  body { font-family: 'Figtree', sans-serif; background: transparent; padding: 0.75rem; font-size: 13px; color: #05042E; }\n  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }\n  .card { background: #fff; border: 0.5px solid rgba(0,0,0,0.12); border-radius: 12px; overflow: hidden; }\n  .card-header { background: #469BC0; padding: 0.75rem 1.25rem; display: flex; align-items: center; justify-content: space-between; }\n  .card-title { font-size: 11px; font-weight: 700; color: #fff; text-transform: uppercase; letter-spacing: 0.07em; }\n  .card-body { padding: 1rem; display: flex; flex-direction: column; gap: 10px; }\n  .field-group { display: flex; flex-direction: column; gap: 4px; }\n  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }\n  label { font-size: 10px; font-weight: 600; color: #888780; text-transform: uppercase; letter-spacing: 0.05em; }\n  .required { color: #A3E851; }\n  input, select, textarea { font-size: 13px; font-family: 'Figtree', sans-serif; border: 0.5px solid rgba(0,0,0,0.15); border-radius: 6px; padding: 7px 10px; color: #05042E; outline: none; width: 100%; background: #fff; }\n  input:focus, select:focus, textarea:focus { border-color: #469BC0; }\n  textarea { resize: vertical; min-height: 60px; }\n  input::placeholder, textarea::placeholder { color: #b0aeb8; }\n  .hint { font-size: 11px; color: #469BC0; margin-bottom: 4px; }\n  .actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 0.75rem; padding: 0 0.75rem 0.75rem; }\n  .btn { font-size: 13px; font-weight: 600; padding: 8px 20px; border-radius: 6px; border: none; cursor: pointer; font-family: 'Figtree', sans-serif; }\n  .btn-primary { background: #A3E851; color: #05042E; }\n  .btn-primary:hover { background: #5DC987; }\n  .btn-secondary { background: #E0DFE1; color: #05042E; }\n  .btn-survey { background: #05042E; color: #A3E851; }\n  .btn-survey:hover { background: #469BC0; color: #fff; }\n  .btn-copy { font-size: 10px; font-weight: 600; padding: 3px 10px; border-radius: 20px; border: none; cursor: pointer; background: #A3E851; color: #05042E; font-family: 'Figtree', sans-serif; white-space: nowrap; }\n  .btn-copy:hover { background: #5DC987; }\n  .error { font-size: 11px; color: #dc2626; margin-top: 2px; display: none; }\n</style>\n</head>\n<body>\n<div class=\"grid\">\n  <div class=\"card\">\n    <div class=\"card-header\">\n      <span class=\"card-title\">Customer Information</span>\n    </div>\n    <div class=\"card-body\">\n      <div class=\"field-group\">\n        <label>Customer Name <span class=\"required\">*</span></label>\n        <input type=\"text\" id=\"f_customer_name\" placeholder=\"Enter customer name\"\n          onblur=\"this.value=toTitleCase(this.value)\" />\n        <span class=\"error\" id=\"err_customer_name\">Required</span>\n      </div>\n      <div class=\"field-row\">\n        <div class=\"field-group\">\n          <label>Contact Name <span class=\"required\">*</span></label>\n          <input type=\"text\" id=\"f_contact_name\" placeholder=\"Contact name\"\n            onblur=\"this.value=toTitleCase(this.value)\" />\n        </div>\n        <div class=\"field-group\">\n          <label>Job Title <span class=\"required\">*</span></label>\n          <input type=\"text\" id=\"f_job_title\" placeholder=\"e.g. IT Manager\"\n            onblur=\"this.value=toTitleCase(this.value)\" />\n        </div>\n      </div>\n      <div class=\"field-group\">\n        <label>Contact Number</label>\n        <input type=\"text\" id=\"f_contact_number\" placeholder=\"+44\" />\n      </div>\n      <div class=\"field-group\">\n        <label>Email</label>\n        <input type=\"email\" id=\"f_email\" placeholder=\"name@company.com\"\n          onblur=\"this.value=this.value.toLowerCase()\" />\n      </div>\n    </div>\n  </div>\n\n  <div class=\"card\">\n    <div class=\"card-header\">\n      <span class=\"card-title\">Contract & Compliance</span>\n    </div>\n    <div class=\"card-body\">\n      <div class=\"field-row\">\n        <div class=\"field-group\">\n          <label>DIAL Rating</label>\n          <select id=\"f_dial_rating\">\n            <option value=\"\">Select...</option>\n            <option value=\"DIAL 1\">DIAL 1</option>\n            <option value=\"DIAL 2\">DIAL 2</option>\n            <option value=\"DIAL 3\">DIAL 3</option>\n          </select>\n        </div>\n        <div class=\"field-group\">\n          <label>DIAL Expiry</label>\n          <input type=\"date\" id=\"f_dial_expiry\" />\n        </div>\n      </div>\n      <div class=\"field-row\">\n        <div class=\"field-group\">\n          <label>MSA Signed</label>\n          <select id=\"f_msa\">\n            <option value=\"\">Select...</option>\n            <option value=\"Yes\">Yes</option>\n            <option value=\"No\">No</option>\n            <option value=\"Pending\">Pending</option>\n          </select>\n        </div>\n        <div class=\"field-group\">\n          <label>Account Manager</label>\n          <select id=\"f_account_manager\">\n            <option value=\"\">Select...</option>\n            <option value=\"Dean Ivell\">Dean Ivell</option>\n            <option value=\"Matthew Harrop\">Matthew Harrop</option>\n            <option value=\"Eimear Finn\">Eimear Finn</option>\n            <option value=\"James Lownds\">James Lownds</option>\n          </select>\n        </div>\n      </div>\n      <div class=\"field-group\">\n        <label>Default Collection Instructions</label>\n        <textarea id=\"f_default_instructions\"\n          placeholder=\"Any standing instructions for collections at this site...\"></textarea>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"card\">\n    <div class=\"card-header\">\n      <span class=\"card-title\">Address</span>\n    </div>\n    <div class=\"card-body\">\n      <div class=\"field-group\">\n        <label>Address Line 1</label>\n        <input type=\"text\" id=\"f_address1\" placeholder=\"Address line 1\"\n          onblur=\"this.value=toTitleCase(this.value)\" />\n      </div>\n      <div class=\"field-group\">\n        <label>Address Line 2</label>\n        <input type=\"text\" id=\"f_address2\" placeholder=\"Address line 2\"\n          onblur=\"this.value=toTitleCase(this.value)\" />\n      </div>\n      <div class=\"field-row\">\n        <div class=\"field-group\">\n          <label>City</label>\n          <input type=\"text\" id=\"f_city\" placeholder=\"City\"\n            onblur=\"this.value=toTitleCase(this.value)\" />\n        </div>\n        <div class=\"field-group\">\n          <label>Postcode</label>\n          <input type=\"text\" id=\"f_postcode\" placeholder=\"Postcode\"\n            onblur=\"this.value=this.value.toUpperCase()\" />\n        </div>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"card\">\n    <div class=\"card-header\">\n      <span class=\"card-title\">Site Contact</span>\n      <button class=\"btn-copy\" onclick=\"copyContactDetails()\">Same as customer contact</button>\n    </div>\n    <div class=\"card-body\">\n      <p class=\"hint\">Person on site during collections — can differ from main contact</p>\n      <div class=\"field-group\">\n        <label>Site Contact Name</label>\n        <input type=\"text\" id=\"f_site_contact\" placeholder=\"Site contact name\"\n          onblur=\"this.value=toTitleCase(this.value)\" />\n      </div>\n      <div class=\"field-row\">\n        <div class=\"field-group\">\n          <label>Phone</label>\n          <input type=\"text\" id=\"f_site_phone\" placeholder=\"+44\" />\n        </div>\n        <div class=\"field-group\">\n          <label>Email</label>\n          <input type=\"email\" id=\"f_site_email\" placeholder=\"site@company.com\"\n            onblur=\"this.value=this.value.toLowerCase()\" />\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n\n<div class=\"actions\">\n  <button class=\"btn btn-survey\" onclick=\"window.triggerSurvey()\">Site Survey</button>\n  <button class=\"btn btn-primary\" onclick=\"window.createCustomer()\">Create Customer</button>\n</div>\n\n<script>\nfunction copyContactDetails() {\n  var name = document.getElementById('f_site_contact');\n  var phone = document.getElementById('f_site_phone');\n  var email = document.getElementById('f_site_email');\n  var srcName = document.getElementById('f_contact_name');\n  var srcPhone = document.getElementById('f_contact_number');\n  var srcEmail = document.getElementById('f_email');\n  if (name && srcName) name.value = srcName.value;\n  if (phone && srcPhone) phone.value = srcPhone.value;\n  if (email && srcEmail) email.value = srcEmail.value;\n}\n</script>\n</body>\n</html>",
    "js": "function toTitleCase(str) {\n  if (!str) return str;\n  return str.replace(/\\w\\S*/g, function (txt) {\n    return txt.charAt(0).toUpperCase() + txt.substr(1).toLowerCase();\n  });\n}\nfunction v(id) {\n  var el = document.getElementById(id);\n  return el ? el.value : '';\n}\nfunction validate() {\n  var name = v('f_customer_name');\n  var err = document.getElementById('err_customer_name');\n  if (!name.trim()) {\n    if (err) err.style.display = 'block';\n    return false;\n  }\n  if (err) err.style.display = 'none';\n  return true;\n}\nfunction collectData() {\n  return {\n    customer_name: toTitleCase(v('f_customer_name')),\n    contact_name: toTitleCase(v('f_contact_name')),\n    job_title: toTitleCase(v('f_job_title')),\n    contact_number: v('f_contact_number'),\n    email: v('f_email').toLowerCase(),\n    dial_rating: v('f_dial_rating'),\n    dial_expiry: v('f_dial_expiry') || null,\n    msa_signed: v('f_msa'),\n    account_manager: v('f_account_manager'),\n    default_instructions: v('f_default_instructions'),\n    address1: toTitleCase(v('f_address1')),\n    address2: toTitleCase(v('f_address2')),\n    city: toTitleCase(v('f_city')),\n    postcode: v('f_postcode').toUpperCase(),\n    site_contact: toTitleCase(v('f_site_contact')),\n    site_phone: v('f_site_phone'),\n    site_email: v('f_site_email').toLowerCase()\n  };\n}\nwindow.createCustomer = function () {\n  if (!validate()) return;\n  appsmith.updateModel(collectData());\n  appsmith.triggerEvent('onCreateCustomer');\n};\nwindow.triggerSurvey = function () {\n  if (!validate()) return;\n  appsmith.updateModel(collectData());\n  appsmith.triggerEvent('onSurveyFirst');\n};\nappsmith.onReady(function () {});\nappsmith.onModelChange(function () {});"
