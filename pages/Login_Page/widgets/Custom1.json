    "css": "",
    "html": "<div style=\"min-height:100vh; background:#Ffff; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:2rem;\">\n  <div style=\"margin-bottom:2rem; text-align:center;\">\n    <img src=\"https://www.mbhglobal.co.uk/wp-content/uploads/2026/06/Orbit_logo_transparent_cropped.png\" alt=\"Orbit\" style=\"height:80px; margin-bottom:10px;\" />\n    <p style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:13px; color:#64748b; font-weight:500; letter-spacing:0.08em; text-transform:uppercase; margin:0;\">ITAD Management System</p>\n  </div>\n  <div style=\"background:#fff; border:1px solid #e2e8f0; border-radius:16px; padding:2rem 2.5rem; width:100%; max-width:400px;\">\n    <h2 style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:20px; font-weight:600; color:#1A2E3B; margin:0 0 6px;\">Welcome back</h2>\n    <p style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:14px; color:#64748b; margin:0 0 1.75rem;\">Sign in to your Orbit account</p>\n\n    <button id=\"google_btn\" style=\"width:100%; display:flex; align-items:center; justify-content:center; gap:10px; padding:11px 16px; background:#fff; border:1px solid #e2e8f0; border-radius:10px; cursor:pointer; font-size:14px; font-weight:600; color:#1A2E3B; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;\">\n      <svg width=\"18\" height=\"18\" viewBox=\"0 0 18 18\"><path fill=\"#4285F4\" d=\"M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.874 2.684-6.615z\"/><path fill=\"#34A853\" d=\"M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332C2.438 15.983 5.482 18 9 18z\"/><path fill=\"#FBBC05\" d=\"M3.964 10.71A5.4 5.4 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A9 9 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332z\"/><path fill=\"#EA4335\" d=\"M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0 5.482 0 2.438 2.017.957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z\"/></svg>\n      <span id=\"btn_label\">Sign in with Google</span>\n    </button>\n\n    <p id=\"loginError\" style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:12.5px; color:#DC2626; margin:12px 0 0; min-height:16px; text-align:center;\"></p>\n\n    <p style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:12px; color:#94a3b8; text-align:center; margin:1.5rem 0 0; line-height:1.6;\">\n      Access is restricted to <strong style=\"color:#64748b;\">@mbhglobal.co.uk</strong> accounts.<br>Contact your administrator if you need access.\n    </p>\n  </div>\n  <div style=\"margin-top:2rem; display:flex; align-items:center; gap:10px;\">\n    <img src=\"https://www.mbhglobal.co.uk/wp-content/uploads/2026/06/Orbit_logo_transparent_cropped.png\" alt=\"Orbit\" style=\"height:24px;\" />\n    <span style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:13px; color:#94a3b8;\">Powered by <strong style=\"color:#64748b;\">MBH Global</strong></span>\n  </div>\n</div>\n\n<script>\nvar CLIENT_ID = '817700172955-di9olsb34rp2iq4o1ssdlb9ediq2b2lc.apps.googleusercontent.com';\nvar ALLOWED_DOMAIN = 'mbhglobal.co.uk';\nvar tokenClient = null;\n\nfunction showError(msg) {\n  var el = document.getElementById('loginError');\n  if (el) el.textContent = msg || '';\n}\n\nfunction setBtnLabel(text) {\n  var el = document.getElementById('btn_label');\n  if (el) el.textContent = text;\n}\n\nfunction fetchUserInfoAndSignIn(accessToken) {\n  setBtnLabel('Signing in…');\n  showError('');\n  fetch('https://www.googleapis.com/oauth2/v3/userinfo', {\n    headers: { 'Authorization': 'Bearer ' + accessToken }\n  })\n    .then(function(res) { return res.json(); })\n    .then(function(profile) {\n      if (!profile.email) {\n        showError('Could not read your Google account. Please try again.');\n        setBtnLabel('Sign in with Google');\n        return;\n      }\n      var email = profile.email.toLowerCase();\n      var domain = email.split('@')[1];\n      if (domain !== ALLOWED_DOMAIN) {\n        showError('Access is restricted to @' + ALLOWED_DOMAIN + ' accounts.');\n        setBtnLabel('Sign in with Google');\n        return;\n      }\n      appsmith.updateModel({\n        google_email: email,\n        google_name: profile.name || '',\n        google_picture: profile.picture || ''\n      });\n      appsmith.triggerEvent('onGoogleSignIn');\n    })\n    .catch(function(err) {\n      showError('Sign-in failed: ' + err.message);\n      setBtnLabel('Sign in with Google');\n    });\n}\n\nfunction initTokenClient() {\n  if (typeof google === 'undefined' || !google.accounts || !google.accounts.oauth2) {\n    setTimeout(initTokenClient, 100);\n    return;\n  }\n  tokenClient = google.accounts.oauth2.initTokenClient({\n    client_id: CLIENT_ID,\n    scope: 'openid email profile',\n    callback: function(tokenResponse) {\n      if (tokenResponse && tokenResponse.access_token) {\n        fetchUserInfoAndSignIn(tokenResponse.access_token);\n      } else {\n        showError('Sign-in was cancelled or failed. Please try again.');\n      }\n    },\n    error_callback: function(err) {\n      showError('Sign-in error: ' + (err && err.type ? err.type : 'unknown error'));\n    }\n  });\n}\n\nfunction loadGoogleScript() {\n  if (document.getElementById('google-identity-script')) {\n    initTokenClient();\n    return;\n  }\n  var script = document.createElement('script');\n  script.id = 'google-identity-script';\n  script.src = 'https://accounts.google.com/gsi/client';\n  script.async = true;\n  script.defer = true;\n  script.onload = initTokenClient;\n  script.onerror = function() { showError('Failed to load Google sign-in. Check your connection and try again.'); };\n  document.head.appendChild(script);\n}\n\nfunction initWhenReady() {\n  if (typeof appsmith === 'undefined' || !appsmith.onReady) {\n    setTimeout(initWhenReady, 50);\n    return;\n  }\n  appsmith.onReady(function() {\n    loadGoogleScript();\n\n    var btn = document.getElementById('google_btn');\n    if (btn) btn.addEventListener('click', function() {\n      if (!tokenClient) {\n        showError('Still loading, please try again in a moment.');\n        return;\n      }\n      showError('');\n      tokenClient.requestAccessToken();\n    });\n\n    appsmith.onModelChange(function(model) {\n      if (model.loginErrorMessage) {\n        showError(model.loginErrorMessage);\n      }\n    });\n  });\n}\n\ninitWhenReady();\n</script>",
    "js": "window.signIn = function () {\n  var email = document.getElementById('email').value.trim();\n  var password = document.getElementById('password').value;\n  if (!email || !password) {\n    var err = document.getElementById('error_msg');\n    if (err) {\n      err.textContent = 'Please enter your email and password';\n      err.style.display = 'block';\n    }\n    return;\n  }\n  appsmith.updateModel({\n    email: email,\n    password: password\n  });\n  appsmith.triggerEvent('onSignIn');\n};\nwindow.signInGoogle = function () {\n  appsmith.triggerEvent('onGoogleSignIn');\n};\n\n// allow Enter key to submit\ndocument.addEventListener('keydown', function (e) {\n  if (e.key === 'Enter') {\n    var active = document.activeElement;\n    if (active && (active.id === 'email' || active.id === 'password')) {\n      window.signIn();\n    }\n  }\n});\nappsmith.onReady(function () {\n  var btn = document.getElementById('googleBtn');\n  if (btn) {\n    btn.addEventListener('mouseover', function () {\n      btn.style.background = '#f8fafc';\n      btn.style.borderColor = '#cbd5e1';\n    });\n    btn.addEventListener('mouseout', function () {\n      btn.style.background = '#fff';\n      btn.style.borderColor = '#e2e8f0';\n    });\n  }\n});\nappsmith.onModelChange(function (model) {\n  if (model.error) {\n    var err = document.getElementById('error_msg');\n    if (err) {\n      err.textContent = model.error;\n      err.style.display = 'block';\n    }\n  }\n});"
  },
