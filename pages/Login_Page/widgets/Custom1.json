    "css": "",
    "html": "<div style=\"min-height:100vh; background:#F4F6F8; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:2rem;\">\n  <div style=\"margin-bottom:2rem; text-align:center;\">\n    <img src=\"https://www.mbhglobal.co.uk/wp-content/uploads/2026/06/Orbit_logo_transparent_cropped.png\" alt=\"Orbit\" style=\"height:80px; margin-bottom:10px;\" />\n    <p style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:13px; color:#64748b; font-weight:500; letter-spacing:0.08em; text-transform:uppercase; margin:0;\">ITAD Management System</p>\n  </div>\n  <div style=\"background:#fff; border:1px solid #e2e8f0; border-radius:16px; padding:2rem 2.5rem; width:100%; max-width:400px;\">\n    <h2 style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:20px; font-weight:600; color:#1A2E3B; margin:0 0 6px;\">Welcome back</h2>\n    <p style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:14px; color:#64748b; margin:0 0 1.75rem;\">Sign in to your Orbit account</p>\n\n    <div id=\"g_signin_button\" style=\"display:flex; justify-content:center; margin-bottom:12px;\"></div>\n\n    <p id=\"loginError\" style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:12.5px; color:#DC2626; margin:8px 0 0; min-height:16px; text-align:center;\"></p>\n\n    <p style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:12px; color:#94a3b8; text-align:center; margin:1.5rem 0 0; line-height:1.6;\">\n      Access is restricted to <strong style=\"color:#64748b;\">@mbhglobal.co.uk</strong> accounts.<br>Contact your administrator if you need access.\n    </p>\n  </div>\n  <div style=\"margin-top:2rem; display:flex; align-items:center; gap:10px;\">\n    <img src=\"https://www.mbhglobal.co.uk/wp-content/uploads/2026/06/Orbit_logo_transparent_cropped.png\" alt=\"Orbit\" style=\"height:24px;\" />\n    <span style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:13px; color:#94a3b8;\">Powered by <strong style=\"color:#64748b;\">MBH Global</strong></span>\n  </div>\n</div>\n\n<script>\nvar CLIENT_ID = '817700172955-di9olsb34rp2iq4o1ssdlb9ediq2b2lc.apps.googleusercontent.com';\nvar ALLOWED_DOMAIN = 'mbhglobal.co.uk';\n\nfunction showError(msg) {\n  var el = document.getElementById('loginError');\n  if (el) el.textContent = msg || '';\n}\n\nfunction decodeJwt(token) {\n  try {\n    var base64Url = token.split('.')[1];\n    var base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');\n    var jsonPayload = decodeURIComponent(atob(base64).split('').map(function(c) {\n      return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);\n    }).join(''));\n    return JSON.parse(jsonPayload);\n  } catch (e) {\n    return null;\n  }\n}\n\nfunction handleCredentialResponse(response) {\n  showError('');\n  var payload = decodeJwt(response.credential);\n  if (!payload || !payload.email) {\n    showError('Could not read your Google account. Please try again.');\n    return;\n  }\n  var email = payload.email.toLowerCase();\n  var domain = email.split('@')[1];\n  if (domain !== ALLOWED_DOMAIN) {\n    showError('Access is restricted to @' + ALLOWED_DOMAIN + ' accounts.');\n    return;\n  }\n  appsmith.updateModel({\n    google_email: email,\n    google_name: payload.name || '',\n    google_picture: payload.picture || ''\n  });\n  appsmith.triggerEvent('onGoogleSignIn');\n}\n\nfunction initGoogleButton() {\n  if (typeof google === 'undefined' || !google.accounts || !google.accounts.id) {\n    setTimeout(initGoogleButton, 100);\n    return;\n  }\n  google.accounts.id.initialize({\n    client_id: CLIENT_ID,\n    callback: handleCredentialResponse\n  });\n  google.accounts.id.renderButton(\n    document.getElementById('g_signin_button'),\n    { theme: 'outline', size: 'large', width: 340, text: 'signin_with' }\n  );\n}\n\nfunction loadGoogleScript() {\n  if (document.getElementById('google-identity-script')) {\n    initGoogleButton();\n    return;\n  }\n  var script = document.createElement('script');\n  script.id = 'google-identity-script';\n  script.src = 'https://accounts.google.com/gsi/client';\n  script.async = true;\n  script.defer = true;\n  script.onload = initGoogleButton;\n  document.head.appendChild(script);\n}\n\nfunction initWhenReady() {\n  if (typeof appsmith === 'undefined' || !appsmith.onReady) {\n    setTimeout(initWhenReady, 50);\n    return;\n  }\n  appsmith.onReady(function() {\n    loadGoogleScript();\n    appsmith.onModelChange(function(model) {\n      if (model.loginErrorMessage) {\n        showError(model.loginErrorMessage);\n      }\n    });\n  });\n}\n\ninitWhenReady();\n</script>",
    "js": "window.signIn = function () {\n  var email = document.getElementById('email').value.trim();\n  var password = document.getElementById('password').value;\n  if (!email || !password) {\n    var err = document.getElementById('error_msg');\n    if (err) {\n      err.textContent = 'Please enter your email and password';\n      err.style.display = 'block';\n    }\n    return;\n  }\n  appsmith.updateModel({\n    email: email,\n    password: password\n  });\n  appsmith.triggerEvent('onSignIn');\n};\nwindow.signInGoogle = function () {\n  appsmith.triggerEvent('onGoogleSignIn');\n};\n\n// allow Enter key to submit\ndocument.addEventListener('keydown', function (e) {\n  if (e.key === 'Enter') {\n    var active = document.activeElement;\n    if (active && (active.id === 'email' || active.id === 'password')) {\n      window.signIn();\n    }\n  }\n});\nappsmith.onReady(function () {\n  var btn = document.getElementById('googleBtn');\n  if (btn) {\n    btn.addEventListener('mouseover', function () {\n      btn.style.background = '#f8fafc';\n      btn.style.borderColor = '#cbd5e1';\n    });\n    btn.addEventListener('mouseout', function () {\n      btn.style.background = '#fff';\n      btn.style.borderColor = '#e2e8f0';\n    });\n  }\n});\nappsmith.onModelChange(function (model) {\n  if (model.error) {\n    var err = document.getElementById('error_msg');\n    if (err) {\n      err.textContent = model.error;\n      err.style.display = 'block';\n    }\n  }\n});"
  },
