    "css": "",
    "html": "<div style=\"min-height:100vh; background:#F4F6F8; display:flex; flex-direction:column; align-items:center; justify-content:center; padding:2rem;\">\n  <div style=\"margin-bottom:2rem; text-align:center;\">\n    <img src=\"https://www.mbhglobal.co.uk/wp-content/uploads/2026/06/Orbit_logo_transparent_cropped.png\" alt=\"Orbit\" style=\"height:80px; margin-bottom:10px;\" />\n    <p style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:13px; color:#64748b; font-weight:500; letter-spacing:0.08em; text-transform:uppercase; margin:0;\">ITAD Management System</p>\n  </div>\n  <div style=\"background:#fff; border:1px solid #e2e8f0; border-radius:16px; padding:2rem 2.5rem; width:100%; max-width:400px;\">\n    <h2 style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:20px; font-weight:600; color:#1A2E3B; margin:0 0 6px;\">Welcome back</h2>\n    <p style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:14px; color:#64748b; margin:0 0 1.75rem;\">Sign in to your Orbit account</p>\n\n    <form onsubmit=\"event.preventDefault(); handleLogin();\">\n      <label style=\"display:block; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:13px; font-weight:500; color:#1A2E3B; margin-bottom:6px;\">Email</label>\n      <input\n        id=\"emailInput\"\n        type=\"email\"\n        placeholder=\"you@mbhglobal.co.uk\"\n        style=\"width:100%; padding:11px 14px; border:1px solid #e2e8f0; border-radius:10px; font-size:14px; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; color:#1A2E3B; margin-bottom:14px; box-sizing:border-box;\"\n      />\n\n      <label style=\"display:block; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:13px; font-weight:500; color:#1A2E3B; margin-bottom:6px;\">Password</label>\n      <input\n        id=\"passwordInput\"\n        type=\"password\"\n        placeholder=\"••••••••\"\n        style=\"width:100%; padding:11px 14px; border:1px solid #e2e8f0; border-radius:10px; font-size:14px; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; color:#1A2E3B; margin-bottom:8px; box-sizing:border-box;\"\n      />\n\n      <p id=\"loginError\" style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:12.5px; color:#DC2626; margin:0 0 12px; min-height:16px;\"></p>\n\n      <button\n        id=\"loginBtn\"\n        type=\"submit\"\n        style=\"width:100%; padding:12px 16px; background:#1A2E3B; border:none; border-radius:10px; cursor:pointer; font-size:14px; font-weight:600; color:#fff; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; margin-bottom:1.5rem;\"\n      >\n        Sign in\n      </button>\n    </form>\n\n    <p style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:12px; color:#94a3b8; text-align:center; margin:0; line-height:1.6;\">\n      Access is restricted to <strong style=\"color:#64748b;\">@mbhglobal.co.uk</strong> accounts.<br>Contact your administrator if you need access.\n    </p>\n  </div>\n  <div style=\"margin-top:2rem; display:flex; align-items:center; gap:10px;\">\n    <img src=\"https://www.mbhglobal.co.uk/wp-content/uploads/2026/06/Orbit_logo_transparent_cropped.png\" alt=\"Orbit\" style=\"height:24px;\" />\n    <span style=\"font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif; font-size:13px; color:#94a3b8;\">Powered by <strong style=\"color:#64748b;\">MBH Global</strong></span>\n  </div>\n</div>\n\n<script>\nfunction handleLogin() {\n  var email = document.getElementById('emailInput').value;\n  var password = document.getElementById('passwordInput').value;\n  var errorEl = document.getElementById('loginError');\n  var btn = document.getElementById('loginBtn');\n\n  errorEl.textContent = '';\n\n  if (!email || !password) {\n    errorEl.textContent = 'Please enter both email and password.';\n    return;\n  }\n\n  btn.textContent = 'Signing in…';\n  btn.disabled = true;\n\n  appsmith.updateModel({ loginEmail: email, loginPassword: password });\n  appsmith.triggerEvent('onLoginSubmit');\n}\n\n// Called by Appsmith after the login query finishes, to reset the\n// button state and/or show an error returned from Supabase.\nfunction resetLoginButton(errorMessage) {\n  var btn = document.getElementById('loginBtn');\n  var errorEl = document.getElementById('loginError');\n  btn.textContent = 'Sign in';\n  btn.disabled = false;\n  if (errorMessage) {\n    errorEl.textContent = errorMessage;\n  }\n}\n\nappsmith.onReady(function() {\n  appsmith.onModelChange(function(model) {\n    if (model.loginErrorMessage) {\n      resetLoginButton(model.loginErrorMessage);\n    }\n  });\n});\n</script>",
    "js": "window.signInGoogle = function () {\n  appsmith.triggerEvent('onGoogleSignIn');\n};\nappsmith.onReady(function () {\n  var btn = document.getElementById('googleBtn');\n  if (btn) {\n    btn.addEventListener('mouseover', function () {\n      btn.style.background = '#f8fafc';\n      btn.style.borderColor = '#cbd5e1';\n    });\n    btn.addEventListener('mouseout', function () {\n      btn.style.background = '#fff';\n      btn.style.borderColor = '#e2e8f0';\n    });\n  }\n});"
  },
